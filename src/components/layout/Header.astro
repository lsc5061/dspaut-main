---
// src/components/layout/Header.astro
interface Props {
  lang: string;
}

const { lang } = Astro.props;
const isKo = lang === 'ko';

const homePath = isKo ? '/ko/' : '/';
const productsPath = isKo ? '/ko/#products' : '/#products';
const softwarePath = isKo ? '/ko/#software' : '/#software';
const resourcesPath = (() => {
  const base = import.meta.env.PUBLIC_DOWNLOAD_URL || "https://download.dspaut.com";
  return `${base.replace(/\/$/, '')}/${isKo ? 'ko/' : ''}`;
})();
const contactPath = isKo ? '/ko/#contact-sales' : '/#contact-sales';
const aboutPath = isKo ? '/ko/about/' : '/about/';

const portalUrl = (() => {
  const base = import.meta.env.PUBLIC_SUPPORT_URL || "https://support.dspaut.com";
  return `${base.replace(/\/$/, '')}/${lang}/`;
})();

const navItems = isKo ? [
  { label: "회사 소개", href: aboutPath },
  { label: "제품 정보", href: productsPath },
  { label: "소프트웨어", href: softwarePath },
  { label: "자료실", href: resourcesPath, isExternal: true },
  { label: "기술 지원", href: portalUrl, isExternal: true }
] : [
  { label: "Company", href: aboutPath },
  { label: "Products", href: productsPath },
  { label: "Software", href: softwarePath },
  { label: "Download", href: resourcesPath, isExternal: true },
  { label: "Support", href: portalUrl, isExternal: true }
];

const contactLabel = isKo ? "도입 문의" : "Inquiry";
const langSwitchLabel = isKo ? "English" : "한국어";

// Dynamic language switcher that preserves the current subpage pathname
const pathname = Astro.url.pathname;
const cleanPathname = pathname.endsWith('/') ? pathname : `${pathname}/`;
const langSwitchHref = isKo 
  ? (cleanPathname.replace(/^\/ko\//, '/') || '/') 
  : `/ko${cleanPathname}`;
---

<header class="sticky top-0 z-50 w-full backdrop-blur-md bg-[#0C1929]/95 border-b border-slate-800 transition-all duration-300" data-layout-header>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-20">
      <!-- Logo -->
      <div class="flex-shrink-0">
        <a href={homePath} class="flex items-center space-x-2">
          <img src="/favicon.png" alt="DSPAUT Logo" class="h-8 w-8 object-contain" />
          <span class="text-2xl font-bold font-display tracking-tight text-white flex items-center">
            DSPAUT
          </span>
        </a>
      </div>
      
      <!-- Desktop Nav -->
      <nav class="hidden md:flex space-x-8">
        {navItems.map((item) => (
          <a 
            href={item.href} 
            target={item.isExternal ? "_blank" : undefined}
            rel={item.isExternal ? "noopener noreferrer" : undefined}
            class="text-sm font-medium text-slate-300 hover:text-primary-cyan hover:border-b-2 hover:border-primary-cyan pb-1 transition-all duration-200"
          >
            {item.label}
          </a>
        ))}
      </nav>
      
      <!-- Right Side: Lang & Action -->
      <div class="hidden md:flex items-center space-x-4">
        <a href={langSwitchHref} class="text-xs font-semibold text-slate-400 hover:text-white px-2 py-1 border border-slate-700 rounded hover:border-slate-500 transition-all">
          {langSwitchLabel}
        </a>
        <a href={contactPath} class="inline-flex items-center justify-center px-4 py-2 text-xs font-bold text-slate-900 bg-primary-cyan hover:bg-[#00cbe6] rounded-md shadow-sm transition-all duration-200">
          {contactLabel}
        </a>
      </div>
      
      <!-- Mobile Menu Button -->
      <div class="md:hidden flex items-center space-x-2">
        <a href={langSwitchHref} class="text-xs text-slate-400 border border-slate-700 px-2 py-1 rounded">
          {langSwitchLabel.substring(0, 2)}
        </a>
        <button class="mobile-menu-btn text-slate-300 hover:text-white focus:outline-none p-2 rounded-md hover:bg-slate-800" aria-label="Toggle mobile menu">
          <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16m-7 6h7" />
          </svg>
        </button>
      </div>
    </div>
  </div>
  
  <!-- Mobile Menu Panel -->
  <div class="mobile-menu hidden md:hidden bg-[#0C1929] border-b border-slate-800 transition-all duration-300">
    <div class="px-2 pt-2 pb-4 space-y-1 sm:px-3">
      {navItems.map((item) => (
        <a 
          href={item.href} 
          target={item.isExternal ? "_blank" : undefined}
          rel={item.isExternal ? "noopener noreferrer" : undefined}
          class="block px-3 py-2 rounded-md text-base font-medium text-slate-300 hover:text-white hover:bg-slate-800"
        >
          {item.label}
        </a>
      ))}
      <div class="border-t border-slate-800 my-2 pt-2">
        <a href={contactPath} class="block w-full text-center px-4 py-3 text-sm font-bold text-slate-900 bg-primary-cyan rounded-md shadow-sm">
          {contactLabel}
        </a>
      </div>
    </div>
  </div>
</header>

<script>
  function initMobileMenu() {
    const headers = document.querySelectorAll('[data-layout-header]');
    headers.forEach(header => {
      const btn = header.querySelector('.mobile-menu-btn');
      const menu = header.querySelector('.mobile-menu');
      if (btn && menu) {
        btn.addEventListener('click', () => {
          menu.classList.toggle('hidden');
        });
      }
    });
  }
  document.addEventListener('DOMContentLoaded', initMobileMenu);
</script>
