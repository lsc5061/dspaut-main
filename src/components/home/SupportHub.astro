---
// src/components/home/SupportHub.astro
interface Props {
  lang: string;
  data: any;
}

const { lang, data } = Astro.props;
const supportHub = data.supportHub;
const basePortalUrl = import.meta.env.PUBLIC_PORTAL_URL || "https://support.dspaut.com";
const portalUrl = `${basePortalUrl.replace(/\/$/, '')}/${lang}/`;
const resourcesPath = lang === 'ko' ? 'https://download.dspaut.com/ko' : 'https://download.dspaut.com';
---

<section id="resources" class="py-20 bg-[#0C1929] border-t border-b border-slate-800 scroll-mt-24 relative overflow-hidden" data-support-hub>
  <!-- Dynamic multi-anchor support for old links -->
  <div id="demo-proof" class="scroll-mt-24 absolute top-0"></div>
  
  <!-- Glowing Background Accents -->
  <div class="absolute -top-40 -left-40 w-96 h-96 bg-primary-cyan/5 rounded-full blur-3xl pointer-events-none"></div>
  <div class="absolute -bottom-40 -right-40 w-96 h-96 bg-blue-500/5 rounded-full blur-3xl pointer-events-none"></div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    <!-- Section Header -->
    <div class="text-center max-w-3xl mx-auto space-y-4 mb-12">
      <span class="text-xs font-mono bg-slate-950 text-primary-cyan border border-primary-cyan/20 px-3 py-1 rounded-full font-bold uppercase tracking-wider inline-block mb-2">
        {supportHub.badge}
      </span>
      <h2 class="text-3xl font-extrabold text-white tracking-tight font-display">
        {supportHub.title}
      </h2>
      <p class="text-slate-300 text-base" set:html={supportHub.description}>
      </p>
    </div>

    <!-- 좌우 2열 그리드 구조 (좌측: 비디오 및 실증 지표, 우측: 핵심 다운로드 3종 및 포털 바로가기) -->
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 items-stretch">
      
      <!-- Left Column: Video & Proof Metrics (lg:col-span-6) -->
      <div class="lg:col-span-6 flex flex-col justify-between space-y-6 bg-slate-900/40 text-white p-6 sm:p-8 rounded-xl border border-slate-800/80 shadow-xl">
        <!-- Pulsing Video area -->
        <div class="play-video-btn relative bg-slate-950 border border-slate-800/85 rounded-xl overflow-hidden aspect-video cursor-pointer group flex items-center justify-center">
          <img 
            src="https://img.youtube.com/vi/ftx1ohnWXlY/maxresdefault.jpg" 
            alt="NDT Field Scan Demo" 
            class="absolute inset-0 w-full h-full object-cover opacity-85 group-hover:scale-105 group-hover:opacity-70 transition-all duration-500"
          />
          <div class="absolute inset-0 bg-slate-950/20 group-hover:bg-slate-950/40 transition-all duration-300"></div>
          <div class="relative z-10 w-16 h-16 rounded-full bg-primary-cyan hover:bg-[#00cbe6] text-slate-900 flex items-center justify-center shadow-lg transition-transform duration-300 transform group-hover:scale-110">
            <div class="absolute inset-0 rounded-full bg-primary-cyan animate-ping opacity-30 pointer-events-none"></div>
            <svg class="w-6 h-6 ml-0.5 fill-current" viewBox="0 0 24 24">
              <path d="M8 5v14l11-7z" />
            </svg>
          </div>
          <div class="absolute bottom-3 left-3 bg-slate-950/80 border border-slate-850 rounded px-2.5 py-1 text-xs font-mono tracking-wider text-primary-cyan flex items-center space-x-1 backdrop-blur-sm">
            <span class="w-1.5 h-1.5 bg-red-500 rounded-full animate-pulse"></span>
            <span>{supportHub.videoBadge}</span>
          </div>
        </div>
        
        <!-- Tech validation indicators -->
        <div class="space-y-4 pt-4 border-t border-slate-800">
          <h3 class="text-base font-bold text-white flex items-center space-x-2">
            <span class="w-2 h-2 bg-primary-cyan rounded-full animate-pulse"></span>
            <span>{supportHub.videoTitle}</span>
          </h3>
          <div class="grid grid-cols-2 gap-4 text-sm leading-relaxed text-slate-300">
            {supportHub.videoSpecs.map((spec: any) => (
              <div>
                <span class="block text-xs font-sans font-semibold tracking-wider uppercase text-primary-cyan">{spec.label}</span>
                <span class="font-bold text-white text-sm sm:text-base">{spec.value}</span>
              </div>
            ))}
          </div>
        </div>
      </div>
      
      <!-- Right Column: Materials & Support Portal (lg:col-span-6) -->
      <div class="lg:col-span-6 flex flex-col justify-between space-y-6">
        <!-- Resource Hub Link Card (Dark Glassmorphism) -->
        <div class="bg-slate-900/40 border border-slate-800/80 rounded-xl p-6 sm:p-8 shadow-sm flex flex-col justify-between flex-grow group">
          <div>
            <div class="inline-flex items-center space-x-1 bg-slate-950 border border-slate-850 rounded-full px-2.5 py-0.5 text-xs text-slate-400 font-bold uppercase tracking-wider">
              <span>{supportHub.resourceHub.badge}</span>
            </div>
            <h3 class="text-xl font-extrabold text-white mt-3 leading-snug font-display">
              {supportHub.resourceHub.title}
            </h3>
            <p class="text-sm text-slate-300 mt-1.5 leading-relaxed font-medium">
              {supportHub.resourceHub.desc}
            </p>
          </div>
          <div class="pt-6">
            <a href={resourcesPath} class="inline-flex w-full items-center justify-center space-x-1.5 text-sm font-bold text-slate-950 bg-primary-cyan hover:bg-cyan-400 px-4 py-3.5 rounded-lg transition-all duration-200 hover:-translate-y-0.5 shadow-lg shadow-primary-cyan/10">
              <span>{supportHub.resourceHub.cta}</span>
            </a>
          </div>
        </div>

        <!-- Support Portal Entry (Glowing Card) -->
        <div class="relative flex-grow flex">
          <div class="absolute -inset-0.5 bg-gradient-to-r from-primary-cyan to-blue-600 rounded-xl blur opacity-30 pointer-events-none"></div>
          <div class="relative w-full bg-[#0C1929]/80 border border-primary-cyan/20 rounded-xl p-6 sm:p-8 flex flex-col justify-between text-white shadow-xl overflow-hidden">
            <!-- Backdrop pattern -->
            <div class="absolute -right-12 -bottom-12 w-32 h-32 rounded-full border border-primary-cyan/5 pointer-events-none"></div>
            <div>
              <div class="inline-flex items-center space-x-1 bg-slate-950 border border-slate-850 rounded-full px-2.5 py-0.5 text-xs text-primary-cyan font-bold uppercase tracking-wider">
                <span class="w-1.5 h-1.5 bg-primary-cyan rounded-full animate-ping"></span>
                <span>{supportHub.portal.badge}</span>
              </div>
              <h3 class="text-xl font-extrabold text-white mt-3 leading-snug font-display">
                {supportHub.portal.title}
              </h3>
              <p class="text-sm text-slate-300 mt-1.5 leading-relaxed font-medium">
                {supportHub.portal.desc}
              </p>
            </div>
            <div class="pt-6">
              <a href={portalUrl} target="_blank" class="inline-flex w-full items-center justify-center space-x-1.5 text-sm font-bold text-slate-900 bg-primary-cyan hover:bg-cyan-400 px-4 py-3.5 rounded-lg shadow-lg shadow-primary-cyan/20 transition-all duration-200 hover:-translate-y-0.5">
                <span>{supportHub.portal.cta}</span>
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Video Modal -->
  <div class="video-modal fixed inset-0 z-[100] flex items-center justify-center p-4 bg-slate-950/90 backdrop-blur-md hidden opacity-0 transition-opacity duration-300">
    <div class="relative w-full max-w-4xl bg-slate-900 border border-slate-800 rounded-2xl overflow-hidden shadow-2xl aspect-video">
      <button class="close-video-modal absolute top-4 right-4 z-50 w-10 h-10 rounded-full bg-slate-950/80 border border-slate-800 text-white hover:bg-slate-800 hover:text-primary-cyan flex items-center justify-center transition shadow-lg text-lg font-bold">
        ✕
      </button>
      <iframe 
        class="demo-video-iframe w-full h-full" 
        src="" 
        title="NDT Field Scan Demo Video" 
        frameborder="0" 
        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share" 
        allowfullscreen
      ></iframe>
    </div>
  </div>
</section>

<script>
  // =========================================================================
  // Encapsulated Video Modal Controller
  // =========================================================================
  function initSupportHubVideos() {
    const containers = document.querySelectorAll('[data-support-hub]');
    containers.forEach(container => {
      const playBtn = container.querySelector('.play-video-btn');
      const videoModal = container.querySelector('.video-modal') as HTMLElement;
      const videoIframe = container.querySelector('.demo-video-iframe');
      const closeModalBtn = container.querySelector('.close-video-modal');

      if (!playBtn || !videoModal || !videoIframe || !closeModalBtn) return;

      const videoSrc = "https://www.youtube.com/embed/ftx1ohnWXlY?autoplay=1"; // YouTube DEEPSOUND B3 2026 model promo demo

      const playVideo = () => {
        videoIframe.setAttribute('src', videoSrc);
        videoModal.classList.remove('hidden');
        setTimeout(() => {
          videoModal.classList.remove('opacity-0');
          videoModal.classList.add('opacity-100');
        }, 10);
      };

      const closeVideo = () => {
        videoModal.classList.remove('opacity-100');
        videoModal.classList.add('opacity-0');
        setTimeout(() => {
          videoModal.classList.add('hidden');
          videoIframe.setAttribute('src', ''); // stop playing
        }, 300);
      };

      playBtn.addEventListener('click', playVideo);
      closeModalBtn.addEventListener('click', closeVideo);
      videoModal.addEventListener('click', (e) => {
        if (e.target === videoModal) closeVideo();
      });

      // Keyboard ESC key listener for accessibility
      window.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && !videoModal.classList.contains('hidden')) {
          closeVideo();
        }
      });
    });
  }

  document.addEventListener('DOMContentLoaded', initSupportHubVideos);
</script>
