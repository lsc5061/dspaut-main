---
// src/components/home/HomePage.astro
import Hero from './Hero.astro';
import QuickBar from './QuickBar.astro';
import HardwareLineup from './HardwareLineup.astro';
import SoftwareShowcase from './SoftwareShowcase.astro';
import AwardSection from './AwardSection.astro';
import SupportHub from './SupportHub.astro';
import ContactSales from './ContactSales.astro';

interface Props {
  lang: string;
  data: any;
}

const { lang, data } = Astro.props;
---
<div class="homepage-container">
  <Hero data={data} />
  <QuickBar lang={lang} data={data} />
  <HardwareLineup data={data} />
  <SoftwareShowcase lang={lang} data={data} />
  <AwardSection lang={lang} />
  <SupportHub lang={lang} data={data} />
  <ContactSales data={data} />
  
  <slot />
</div>
