---
// src/components/home/AwardSection.astro
interface Props {
  lang: string;
}

const { lang } = Astro.props;
const isKo = lang === 'ko';

const korCert = "/assets/img/brand/global_small_giant_kor.jpg";
const engCert = "/assets/img/brand/global_small_giant_eng.jpg";

// Multi-language text content
const texts = {
  ko: {
    badge: "Award",
    title: "글로벌 강소기업 1,000+ 선정",
    desc: "(주)성산연구소가 중소벤처기업부로부터 독자적인 기술력과 뛰어난 수출 성장 잠재력을 인정받아 2025~2026년도 '글로벌 강소기업 1,000+'에 선정되었습니다.",
  },
  en: {
    badge: "Award",
    title: "Global Leading Company 1,000+",
    desc: "SEONGSANLAB has been designated as a 'Global Leading Company 1,000+' for 2025~2026 by the Ministry of SMEs and Startups, recognizing our advanced technological innovation and global export potential.",
  }
};

const t = isKo ? texts.ko : texts.en;
---

<section id="awards" class="py-24 bg-[#0C1929] text-white border-b border-slate-800 relative overflow-hidden scroll-mt-24">
  <!-- Glowing Background Accents -->
  <div class="absolute top-1/2 left-1/4 -translate-y-1/2 w-[500px] h-[500px] bg-primary-cyan/5 rounded-full blur-[120px] pointer-events-none"></div>
  <div class="absolute top-1/2 right-1/4 -translate-y-1/2 w-[500px] h-[500px] bg-blue-600/5 rounded-full blur-[120px] pointer-events-none"></div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-center">
      
      <!-- Text content (Left on desktop) -->
      <div class="lg:col-span-5 space-y-6 text-center lg:text-left">
        <span class="text-xs font-mono bg-primary-cyan/10 text-primary-cyan border border-primary-cyan/20 px-3 py-1 rounded-full font-bold uppercase tracking-wider inline-block">
          {t.badge}
        </span>
        <h2 class="text-3xl sm:text-4xl font-extrabold text-white font-display tracking-tight leading-tight">
          {t.title}
        </h2>
        <p class="text-slate-300 text-base sm:text-lg leading-relaxed font-medium">
          {t.desc}
        </p>
      </div>

      <!-- Certificates Grid (Right on desktop) -->
      <div class="lg:col-span-7 grid grid-cols-1 sm:grid-cols-2 gap-6 max-w-2xl mx-auto lg:mx-0 w-full">
        <!-- Korean Certificate -->
        <div class="relative w-full aspect-[1/1.4] overflow-hidden rounded-2xl border border-slate-800 bg-slate-950/80 p-2 shadow-2xl flex items-center justify-center">
          <img 
            src={korCert} 
            alt="Korean Certificate" 
            class="w-full h-full object-contain rounded-xl"
            loading="lazy"
          />
        </div>

        <!-- English Certificate -->
        <div class="relative w-full aspect-[1/1.4] overflow-hidden rounded-2xl border border-slate-800 bg-slate-950/80 p-2 shadow-2xl flex items-center justify-center">
          <img 
            src={engCert} 
            alt="English Certificate" 
            class="w-full h-full object-contain rounded-xl"
            loading="lazy"
          />
        </div>
      </div>

    </div>
  </div>
</section>
