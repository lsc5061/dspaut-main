                    <img src="/assets/img/hardware/portable/p5_interactive.png" alt="DSVision Suite" class="w-full h-full object-contain filter drop-shadow-[0_12px_12px_rgba(0,0,0,0.7)] transition-all duration-500 group-hover/carousel:scale-110 group-hover/carousel:-translate-y-2" />
