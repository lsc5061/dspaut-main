                  <img src="/assets/img/software/dsvision/t3_tofd.png" alt="DSVision TOFD UI" class="w-full h-full object-cover opacity-90" />
                  <div class="absolute top-2 right-2 flex items-center space-x-1 bg-slate-950/80 px-1.5 py-0.5 rounded-full border border-slate-800/80">
                    <span class="w-1.5 h-1.5 bg-blue-400 rounded-full animate-ping"></span>
                    <span class="text-[10px] font-mono text-blue-400 font-bold uppercase tracking-wide">{hero.slides.t3.swState}</span>
                  </div>
                </div>
              </div>
              
              <!-- Foreground Product Card -->
              <div class="absolute bottom-2 left-2 right-2 h-[128px] z-20 bg-slate-900/90 border border-slate-750/70 rounded-xl p-3 shadow-2xl transition-all duration-500 transform rotate-2 group-hover/carousel:rotate-[0deg] group-hover/carousel:translate-y-[2px] group-hover/carousel:scale-[1.01] flex items-center justify-between">
                <div class="w-[53%] flex flex-col justify-between h-full">
                  <div class="flex flex-col space-y-1">
                    <div class="flex items-center space-x-1.5">
                      <span class="text-[11px] font-bold text-blue-400 bg-blue-400/10 px-1.5 py-0.5 rounded border border-blue-400/20 uppercase tracking-wide inline-block mb-2">{hero.slides.t3.badge}</span>
                      <span class="text-[10px] font-mono text-slate-400 bg-slate-800 px-1.5 py-0.5 rounded-full inline-block mb-2">{hero.slides.t3.lcd}</span>
                    </div>
                    <h3 class="text-sm font-extrabold text-white tracking-tight">{hero.slides.t3.title}</h3>
                    <p class="text-xs text-slate-400 leading-snug line-clamp-2">{hero.slides.t3.desc}</p>
                  </div>
                  <div class="flex flex-wrap gap-1 mt-1.5">
                    {hero.slides.t3.specs.map((spec: string) => (
                      <span class="text-[10px] bg-slate-850 border border-slate-800 text-slate-300 px-1.5 py-0.5 rounded font-semibold inline-block mb-2">{spec}</span>
                    ))}
                  </div>
                </div>
                <div class="w-[47%] relative h-full flex items-center justify-center">
                  <div class="absolute -top-20 -right-2 w-48 h-48 flex items-center justify-center z-30 pointer-events-none">
                    <img src="/assets/img/hardware/portable/T3_Fornt_2_1.png" alt="DEEPSOUND T3" class="w-full h-full object-contain filter drop-shadow-[0_15px_15px_rgba(0,0,0,0.7)] transition-all duration-500 group-hover/carousel:scale-110 group-hover/carousel:-translate-y-2" />
                  </div>
                </div>
              </div>
            </div>

            <!-- Slide 4: DSVision Software (Hidden by default) -->
            <div class="carousel-slide absolute inset-0 flex flex-col justify-between transition-all duration-700 ease-in-out opacity-0 scale-95 pointer-events-none z-0" data-index="3">
              <!-- Background Software Window -->
              <div class="absolute top-1 left-2 w-[84%] aspect-[1.63] z-10 bg-slate-950/90 border border-slate-800 rounded-xl shadow-2xl overflow-hidden backdrop-blur-sm transition-all duration-500 transform -rotate-3 group-hover/carousel:rotate-[-1deg] group-hover/carousel:translate-y-[-4px] flex flex-col">
                <div class="bg-slate-900 px-3 py-1.5 flex items-center space-x-2 border-b border-slate-800">
                  <div class="flex space-x-1">
                    <span class="w-1.5 h-1.5 rounded-full bg-red-500/80"></span>
                    <span class="w-1.5 h-1.5 rounded-full bg-yellow-500/80"></span>
                    <span class="w-1.5 h-1.5 rounded-full bg-green-500/80"></span>
                  </div>
                  <span class="text-[10px] font-mono text-slate-500 uppercase tracking-wider mx-auto truncate pr-6">{hero.slides.suite.swTitle}</span>
                </div>
                <div class="relative w-full h-full overflow-hidden bg-slate-950">
                  <img src="/assets/img/software/dsvision/p5_ui_multi.png" alt="DSVision Suite UI" class="w-full h-full object-cover opacity-90" />
                  <div class="absolute top-2 right-2 flex items-center space-x-1 bg-slate-950/80 px-1.5 py-0.5 rounded-full border border-slate-800/80">
                    <span class="w-1.5 h-1.5 bg-green-400 rounded-full animate-ping"></span>
                    <span class="text-[10px] font-mono text-green-400 font-bold uppercase tracking-wide">{hero.slides.suite.swState}</span>
                  </div>
                </div>
              </div>
              
              <!-- Foreground Product Card -->
              <div class="absolute bottom-2 left-2 right-2 h-[128px] z-20 bg-slate-900/90 border border-slate-750/70 rounded-xl p-3 shadow-2xl transition-all duration-500 transform rotate-2 group-hover/carousel:rotate-[0deg] group-hover/carousel:translate-y-[2px] group-hover/carousel:scale-[1.01] flex items-center justify-between">
                <div class="w-[53%] flex flex-col justify-between h-full">
                  <div class="flex flex-col space-y-1">
                    <div class="flex items-center space-x-1.5">
                      <span class="text-[11px] font-bold text-green-400 bg-green-400/10 px-1.5 py-0.5 rounded border border-green-400/20 uppercase tracking-wide inline-block mb-2">{hero.slides.suite.badge}</span>
                      <span class="text-[10px] font-mono text-slate-400 bg-slate-800 px-1.5 py-0.5 rounded-full inline-block mb-2">{hero.slides.suite.lcd}</span>
                    </div>
                    <h3 class="text-sm font-extrabold text-white tracking-tight">{hero.slides.suite.title}</h3>
                    <p class="text-xs text-slate-400 leading-snug line-clamp-2">{hero.slides.suite.desc}</p>
                  </div>
