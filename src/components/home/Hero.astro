            <button class="carousel-dot w-2 h-2 rounded-full bg-slate-700 transition-all duration-300 hover:bg-slate-500" data-index="1" aria-label="Go to slide 2"></button>
            <button class="carousel-dot w-2 h-2 rounded-full bg-slate-700 transition-all duration-300 hover:bg-slate-500" data-index="2" aria-label="Go to slide 3"></button>
            <button class="carousel-dot w-2 h-2 rounded-full bg-slate-700 transition-all duration-300 hover:bg-slate-500" data-index="3" aria-label="Go to slide 4"></button>
