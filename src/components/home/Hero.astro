---
// src/components/home/Hero.astro
interface Props {
  data: any;
}

const { data } = Astro.props;
const hero = data.hero;
---

<section class="relative bg-[#0C1929] text-white overflow-hidden py-24 sm:py-32 border-b border-slate-800" data-hero-carousel>
  <!-- Glowing Background Accents -->
  <div class="absolute top-1/4 left-1/4 -translate-x-1/2 -translate-y-1/2 w-96 h-96 bg-primary-cyan/10 rounded-full blur-3xl pointer-events-none"></div>
  <div class="absolute bottom-10 right-1/4 w-[500px] h-[500px] bg-blue-600/10 rounded-full blur-3xl pointer-events-none"></div>
  
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-8 items-center">
      
      <!-- Hero Left Content (6 Cols) -->
      <div class="lg:col-span-6 space-y-8">
        <div class="inline-flex items-center space-x-2 bg-slate-900 border border-slate-800 rounded-full px-3 py-1 text-xs text-primary-cyan font-semibold tracking-wide">
          <span>{hero.badge}</span>
        </div>
        
        <h1 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold tracking-tight font-display leading-tight" set:html={hero.title}>
        </h1>
        
        <p class="text-lg text-slate-300 leading-relaxed max-w-2xl">
          {hero.description}
        </p>
      </div>
      
      <!-- Hero Right Visual (Hardware & Software 3D Layered Mocks - 6 Cols) -->
      <div class="lg:col-span-6 relative flex justify-center items-center">
        <!-- Radial glowing backing -->
        <div class="absolute w-96 h-96 bg-primary-cyan/15 rounded-full blur-3xl"></div>
        
        <!-- 3D layered glass container with Carousel Slider -->
        <div class="carousel-container relative w-full max-w-lg aspect-square bg-slate-950/40 border border-slate-800/80 rounded-2xl p-6 backdrop-blur-md shadow-2xl flex flex-col justify-between overflow-hidden group/carousel">
          
          <!-- Background Scanner Graphic -->
          <div class="absolute -right-16 -bottom-16 w-64 h-64 rounded-full border border-primary-cyan/20 flex items-center justify-center pointer-events-none z-0">
            <div class="w-48 h-48 rounded-full border border-primary-cyan/10 flex items-center justify-center">
              <div class="w-32 h-32 rounded-full border border-primary-cyan/5"></div>
            </div>
          </div>

          <!-- Slides Container -->
          <div class="relative w-full h-[90%] flex items-center justify-center">
            
            <!-- Slide 1: DEEPSOUND P5 (Active by default) -->
            <div class="carousel-slide absolute inset-0 flex flex-col justify-between transition-all duration-700 ease-in-out opacity-100 scale-100 z-10" data-index="0">
              <!-- Background Software Window -->
              <div class="absolute top-1 left-2 w-[84%] aspect-[1.63] z-10 bg-slate-950/90 border border-slate-800 rounded-xl shadow-2xl overflow-hidden backdrop-blur-sm transition-all duration-500 transform -rotate-3 group-hover/carousel:rotate-[-1deg] group-hover/carousel:translate-y-[-4px] flex flex-col">
                <div class="bg-slate-900 px-3 py-1.5 flex items-center space-x-2 border-b border-slate-800">
                  <div class="flex space-x-1">
                    <span class="w-1.5 h-1.5 rounded-full bg-red-500/80"></span>
                    <span class="w-1.5 h-1.5 rounded-full bg-yellow-500/80"></span>
                    <span class="w-1.5 h-1.5 rounded-full bg-green-500/80"></span>
                  </div>
                  <span class="text-[10px] font-mono text-slate-500 uppercase tracking-wider mx-auto truncate pr-6">{hero.slides.p5.swTitle}</span>
                </div>
                <div class="relative w-full h-full overflow-hidden bg-slate-950">
                  <img src="/assets/img/software/dsvision/p5_ui_single.png" alt="DSVision UI" class="w-full h-full object-cover opacity-90" />
                  <div class="absolute top-2 right-2 flex items-center space-x-1 bg-slate-950/80 px-1.5 py-0.5 rounded-full border border-slate-800/80">
                    <span class="w-1.5 h-1.5 bg-green-400 rounded-full animate-ping"></span>
                    <span class="text-[10px] font-mono text-green-400 font-bold uppercase tracking-wide">{hero.slides.p5.swState}</span>
                  </div>
                </div>
              </div>
              
              <!-- Foreground Product Card -->
              <div class="absolute bottom-2 left-2 right-2 h-[128px] z-20 bg-slate-900/90 border border-slate-750/70 rounded-xl p-3 shadow-2xl transition-all duration-500 transform rotate-2 group-hover/carousel:rotate-[0deg] group-hover/carousel:translate-y-[2px] group-hover/carousel:scale-[1.01] flex items-center justify-between">
                <div class="w-[53%] flex flex-col justify-between h-full">
                  <div class="flex flex-col space-y-1">
                    <div class="flex items-center space-x-1.5">
                      <span class="text-[11px] font-bold text-primary-cyan bg-primary-cyan/10 px-1.5 py-0.5 rounded border border-primary-cyan/20 uppercase tracking-wide inline-block mb-2">{hero.slides.p5.badge}</span>
                      <span class="text-[10px] font-mono text-slate-400 bg-slate-800 px-1.5 py-0.5 rounded-full inline-block mb-2">{hero.slides.p5.lcd}</span>
                    </div>
                    <h3 class="text-sm font-extrabold text-white tracking-tight">{hero.slides.p5.title}</h3>
                    <p class="text-xs text-slate-400 leading-snug line-clamp-2">{hero.slides.p5.desc}</p>
                  </div>
                  <div class="flex flex-wrap gap-1 mt-1.5">
                    {hero.slides.p5.specs.map((spec: string) => (
                      <span class="text-[10px] bg-slate-850 border border-slate-800 text-slate-300 px-1.5 py-0.5 rounded font-semibold inline-block mb-2">{spec}</span>
                    ))}
                  </div>
                </div>
                <div class="w-[47%] relative h-full flex items-center justify-center">
                  <div class="absolute -top-24 -right-2 w-52 h-52 flex items-center justify-center z-30 pointer-events-none">
                    <img src="/assets/img/hardware/portable/P5_Catalog_main.png" alt="DEEPSOUND P5" class="w-full h-full object-contain scale-[1.3] translate-y-2 filter drop-shadow-[0_15px_15px_rgba(0,0,0,0.7)] transition-all duration-500 group-hover/carousel:scale-[1.35] group-hover/carousel:-translate-y-1" />
                  </div>
                </div>
              </div>
            </div>

            <!-- Slide 2: DEEPSOUND B3 (Hidden by default) -->
            <div class="carousel-slide absolute inset-0 flex flex-col justify-between transition-all duration-700 ease-in-out opacity-0 scale-95 pointer-events-none z-0" data-index="1">
