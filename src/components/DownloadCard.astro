---
interface ChangelogItem {
  version: string;
  date: string;
  notes: string[];
  downloadUrl?: string;
}

interface Props {
  lang?: string;
  name: string;
  description: string;
  version: string;
  releaseDate: string;
  os: string;
  fileSize: string;
  downloadUrl: string;
  changelog?: ChangelogItem[];
}

const { lang = 'en', name, description, version, releaseDate, os, fileSize, downloadUrl, changelog = [] } = Astro.props;
const isKo = lang === 'ko';
---

<div class="bg-slate-900/60 border border-slate-800 rounded-3xl p-8 backdrop-blur-md relative overflow-hidden group hover:border-primary-cyan/50 hover:shadow-[0_0_30px_rgba(0,229,255,0.1)] transition-all duration-300 flex flex-col justify-between h-fit">
  <!-- Glow Effect on Hover -->
  <div class="absolute -right-16 -bottom-16 w-36 h-36 bg-primary-cyan/5 rounded-full blur-[50px] group-hover:bg-primary-cyan/10 transition-colors duration-300 pointer-events-none"></div>

  <div>
    <!-- Header: Icon & Title -->
    <div class="flex items-start justify-between mb-6">
      <div class="p-4 bg-slate-950 rounded-2xl border border-slate-800/80 group-hover:border-primary-cyan/30 transition-colors duration-300">
        <svg class="w-8 h-8 text-primary-cyan" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"></path>
        </svg>
      </div>
      <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-mono font-bold bg-primary-cyan/10 text-primary-cyan border border-primary-cyan/20 mb-2">
        {version}
      </span>
    </div>

    <!-- Title & Description -->
    <h3 class="text-xl font-bold font-display text-white mb-3 group-hover:text-primary-cyan transition-colors">
      {name}
    </h3>
    <p class="text-slate-400 text-sm sm:text-base leading-relaxed mb-6">
      {description}
    </p>

    <!-- Metadata Details -->
    <div class="border-t border-slate-800/80 pt-6 space-y-3.5 mb-8">
      <div class="flex justify-between items-center text-sm">
        <span class="text-slate-500 font-medium">{isKo ? "업데이트 일자" : "Release Date"}</span>
        <span class="text-slate-300 font-mono">{releaseDate}</span>
      </div>
      <div class="flex justify-between items-center text-sm">
        <span class="text-slate-500 font-medium">{isKo ? "지원 운영체제" : "Supported OS"}</span>
        <span class="text-slate-300 font-sans">{os}</span>
      </div>
      <div class="flex justify-between items-center text-sm">
        <span class="text-slate-500 font-medium">{isKo ? "파일 크기" : "File Size"}</span>
        <span class="text-slate-300 font-mono">{fileSize}</span>
      </div>
    </div>

    <!-- Collapsible Changelog (Version History) -->
    {changelog && changelog.length > 0 && (
      <details class="mt-6 border-t border-slate-800/85 pt-5 pb-2 group/details">
        <summary class="text-sm font-bold text-primary-cyan/95 hover:text-primary-cyan cursor-pointer flex items-center justify-between list-none select-none">
          <span>{isKo ? "버전 히스토리 및 릴리스 노트" : "Version History & Release Notes"}</span>
          <svg class="w-4 h-4 transform group-open/details:rotate-180 transition-transform duration-300 text-slate-500 group-hover/details:text-primary-cyan" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
          </svg>
        </summary>
        <div class="mt-4 space-y-4 max-h-48 overflow-y-auto pr-2 custom-scrollbar">
          {changelog.map((item) => (
            <div class="space-y-1.5 border-b border-slate-900 pb-3 last:border-0 last:pb-0">
              <div class="flex justify-between items-center text-sm">
                <div class="flex items-center space-x-2">
                  <span class="font-bold text-slate-200">{item.version}</span>
                  <span class="text-xs text-slate-500 font-mono">{item.date}</span>
                </div>
                {item.downloadUrl && (
                  <a 
                    href={item.downloadUrl}
                    class="text-xs text-primary-cyan hover:text-[#00cbe6] font-bold hover:underline flex items-center space-x-0.5 transition-colors"
                  >
                    <span>{isKo ? "다운로드" : "Download"}</span>
                    <span class="text-[8px]">➔</span>
                  </a>
                )}
              </div>
              <ul class="list-disc pl-4 space-y-1 text-slate-400 text-xs sm:text-sm leading-relaxed">
                {item.notes.map((note) => (
                  <li>{note}</li>
                ))}
              </ul>
            </div>
          ))}
        </div>
      </details>
    )}
  </div>

  <!-- Download Action Button -->
  <a
    href={downloadUrl}
    class="w-full inline-flex items-center justify-center space-x-2 py-4 px-6 rounded-2xl bg-gradient-to-r from-primary-cyan to-blue-500 hover:from-primary-cyan hover:to-blue-600 text-slate-950 font-bold text-sm sm:text-base shadow-lg hover:shadow-primary-cyan/20 transition-all duration-300"
  >
    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"></path>
    </svg>
    <span>{isKo ? "설치 파일 다운로드" : "Download Installer"}</span>
  </a>
</div>
