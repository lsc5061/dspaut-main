---
interface Props {
  className?: string;
}

const { className = "" } = Astro.props;
---

<div class={`relative bg-gradient-to-br from-slate-100 via-slate-200/95 to-slate-300/90 border border-slate-300/80 rounded-2xl p-4 backdrop-blur-sm shadow-2xl overflow-hidden group flex flex-col items-center justify-center min-h-[380px] ${className}`}>
  
  <!-- 3D & Live Video Control Hint Badge (Top Left) -->
  <div class="absolute top-4 left-4 z-20 bg-slate-900/90 border border-slate-700/80 text-primary-cyan text-xs font-semibold px-3 py-1.5 rounded-full backdrop-blur-md flex items-center space-x-1.5 pointer-events-none shadow-lg transition-opacity duration-300 group-hover:opacity-100">
    <span class="inline-block w-2 h-2 rounded-full bg-primary-cyan animate-pulse"></span>
    <span>🎬 Live Video Screen & 360° Drag</span>
  </div>

  <!-- HTML5 Video Element for THREE.VideoTexture (autoplay, muted, loop, playsinline) -->
  <video 
    id="b3-screen-video" 
    src="/assets/videos/b3_paut_setup.mp4" 
    autoplay 
    muted 
    loop 
    playsinline 
    preload="auto" 
    crossorigin="anonymous"
    style="display: none;"
  ></video>

  <!-- Three.js WebGL Canvas Container -->
  <div 
    id="b3-three-canvas-container" 
    class="w-full h-[360px] sm:h-[400px] rounded-xl cursor-grab active:cursor-grabbing relative z-0"
  ></div>

  <!-- Loading Indicator Bar -->
  <div 
    id="b3-3d-loading-bar" 
    class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 z-20 bg-slate-900/90 border border-slate-700/80 text-slate-200 text-xs px-5 py-2.5 rounded-full backdrop-blur-md flex items-center space-x-2.5 shadow-2xl transition-opacity duration-500 pointer-events-none"
  >
    <span class="w-4 h-4 border-2 border-primary-cyan border-t-transparent rounded-full animate-spin"></span>
    <span class="font-medium">Loading DEEPSOUND B3 3D Model...</span>
  </div>

  <!-- Interactive Control Panel (Bottom Center) -->
  <div class="absolute bottom-4 left-1/2 -translate-x-1/2 z-20 opacity-0 group-hover:opacity-100 transition-all duration-300 flex items-center space-x-2 bg-slate-900/90 border border-slate-700/80 px-3 py-1.5 rounded-full backdrop-blur-md shadow-xl text-xs font-semibold text-slate-200">
    <button 
      id="btn-b3-reset-view"
      type="button"
      class="hover:text-primary-cyan transition-colors px-2.5 py-1 flex items-center space-x-1"
      title="Reset Camera View to Upright Front Perspective"
    >
      <span>🔄 Reset View</span>
    </button>
    <span class="w-px h-3 bg-slate-700"></span>
    <button 
      id="btn-b3-toggle-spin"
      type="button"
      class="hover:text-primary-cyan transition-colors px-2.5 py-1 flex items-center space-x-1"
      title="Toggle Auto Spin"
    >
      <span id="txt-b3-spin">⏸️ Pause Spin</span>
    </button>
    <span class="w-px h-3 bg-slate-700"></span>
    <button 
      id="btn-b3-toggle-video"
      type="button"
      class="hover:text-primary-cyan transition-colors px-2.5 py-1 flex items-center space-x-1"
      title="Play/Pause Live Screen Video"
    >
      <span id="txt-b3-video">🎬 Video On</span>
    </button>
    <span class="w-px h-3 bg-slate-700"></span>
    <button 
      id="btn-b3-fullscreen"
      type="button"
      class="hover:text-primary-cyan transition-colors px-2.5 py-1 flex items-center space-x-1"
      title="Toggle Fullscreen"
    >
      <span>⛶ Fullscreen</span>
    </button>
  </div>
</div>

<!-- Load Three.js, OrbitControls, GLTFLoader, and DRACOLoader Libraries -->
<script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js"></script>
<script is:inline src="https://cdn.jsdelivr.net/npm/three@0.128.0/examples/js/controls/OrbitControls.js"></script>
<script is:inline src="https://cdn.jsdelivr.net/npm/three@0.128.0/examples/js/loaders/GLTFLoader.js"></script>
<script is:inline src="https://cdn.jsdelivr.net/npm/three@0.128.0/examples/js/loaders/DRACOLoader.js"></script>

<script is:inline>
  document.addEventListener('DOMContentLoaded', () => {
    const container = document.getElementById('b3-three-canvas-container');
    const loadingBar = document.getElementById('b3-3d-loading-bar');
    const videoElem = document.getElementById('b3-screen-video');

    const btnReset = document.getElementById('btn-b3-reset-view');
    const btnSpin = document.getElementById('btn-b3-toggle-spin');
    const txtSpin = document.getElementById('txt-b3-spin');
    const btnVideo = document.getElementById('btn-b3-toggle-video');
    const txtVideo = document.getElementById('txt-b3-video');
    const btnFullscreen = document.getElementById('btn-b3-fullscreen');

    if (!container || !window.THREE) return;

    // Force video playback with user interaction fallback
    const startVideo = () => {
      if (videoElem) {
        videoElem.muted = true;
        videoElem.play().catch(() => {});
      }
    };
    startVideo();
    window.addEventListener('click', startVideo, { once: true });
    window.addEventListener('touchstart', startVideo, { once: true });
    window.addEventListener('mousemove', startVideo, { once: true });

    // Three.js Scene Setup
    const scene = new THREE.Scene();
    
    // Perspective Camera tuned for B3 model close-up view
    const camera = new THREE.PerspectiveCamera(
      30, 
      container.clientWidth / container.clientHeight, 
      0.01, 
      1000
    );
    camera.position.set(0, 0.02, 0.45);

    // WebGL Renderer
    const renderer = new THREE.WebGLRenderer({ antialias: true, alpha: true });
    renderer.setSize(container.clientWidth, container.clientHeight);
    renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
    renderer.outputEncoding = THREE.sRGBEncoding;
    renderer.shadowMap.enabled = true;
    renderer.shadowMap.type = THREE.PCFSoftShadowMap;

    // ACESFilmicToneMapping & Exposure Tuning for Deep Dark Charcoal Tones
    renderer.toneMapping = THREE.ACESFilmicToneMapping;
    renderer.toneMappingExposure = 0.85;

    container.appendChild(renderer.domElement);

    // OrbitControls Setup
    const controls = new THREE.OrbitControls(camera, renderer.domElement);
    controls.enableDamping = true;
    controls.dampingFactor = 0.05;
    controls.autoRotate = true;
    controls.autoRotateSpeed = 1.5;
    controls.minDistance = 0.2;
    controls.maxDistance = 5.0;

    // Pure White Studio Lighting (No Cyan/Blue Reflection)
    const ambientLight = new THREE.AmbientLight(0xffffff, 0.45);
    scene.add(ambientLight);

    const dirLight1 = new THREE.DirectionalLight(0xffffff, 0.65);
    dirLight1.position.set(5, 8, 5);
    dirLight1.castShadow = true;
    scene.add(dirLight1);

    const dirLight2 = new THREE.DirectionalLight(0xffffff, 0.25);
    dirLight2.position.set(-5, -2, -5);
    scene.add(dirLight2);

    // Rim Light (Outer Backlight Highlight to separate dark model edges)
    const rimLight = new THREE.DirectionalLight(0xffffff, 0.7);
    rimLight.position.set(0, 5, -5);
    scene.add(rimLight);

    // Contact Ground Drop Shadow under B3 Model
    const shadowCanvas = document.createElement('canvas');
    shadowCanvas.width = 128;
    shadowCanvas.height = 128;
    const ctx = shadowCanvas.getContext('2d');
    const gradient = ctx.createRadialGradient(64, 64, 0, 64, 64, 64);
    gradient.addColorStop(0, 'rgba(15, 23, 42, 0.50)');
    gradient.addColorStop(0.5, 'rgba(15, 23, 42, 0.18)');
    gradient.addColorStop(1, 'rgba(15, 23, 42, 0)');
    ctx.fillStyle = gradient;
    ctx.fillRect(0, 0, 128, 128);

    const shadowTexture = new THREE.CanvasTexture(shadowCanvas);
    const shadowGeo = new THREE.PlaneGeometry(0.32, 0.18);
    const shadowMat = new THREE.MeshBasicMaterial({
      map: shadowTexture,
      transparent: true,
      depthWrite: false
    });
    const shadowPlane = new THREE.Mesh(shadowGeo, shadowMat);
    shadowPlane.rotation.x = -Math.PI / 2;
    shadowPlane.position.set(0, -0.09, 0);
    scene.add(shadowPlane);

    // THREE.VideoTexture Setup
    let videoTexture = null;
    if (videoElem) {
      videoTexture = new THREE.VideoTexture(videoElem);
      videoTexture.minFilter = THREE.LinearFilter;
      videoTexture.magFilter = THREE.LinearFilter;
      videoTexture.format = THREE.RGBAFormat;
      videoTexture.encoding = THREE.sRGBEncoding;
      videoTexture.flipY = false;
    }

    // Configure DRACOLoader for 1.43MB compressed GLB model loading
    let b3ModelGroup = null;
    const dracoLoader = new THREE.DRACOLoader();
    dracoLoader.setDecoderPath('https://www.gstatic.com/draco/versioned/decoders/1.5.6/');
    const loader = new THREE.GLTFLoader();
    loader.setDRACOLoader(dracoLoader);

    loader.load(
      '/assets/models/B3_Edit.glb?v=' + Date.now(),
      (gltf) => {
        b3ModelGroup = gltf.scene;

        // Reset rotation so B3 faces front
        b3ModelGroup.rotation.set(0, 0, 0);

        // Center B3 model exactly at origin (0,0,0)
        const box = new THREE.Box3().setFromObject(b3ModelGroup);
        const center = box.getCenter(new THREE.Vector3());
        
        b3ModelGroup.position.sub(center);

        // EXACT MATERIAL COLOR BINDING
        b3ModelGroup.traverse((child) => {
          if (child.isMesh) {
            const nameUpper = child.name.toUpperCase();
            
            // 1. LCD Screen Video Binding
            if (
              nameUpper.includes('NJ070NA') || 
              nameUpper.includes('LCD MODULE') ||
              child.name === 'Mesh_300'
            ) {
              child.material = new THREE.MeshBasicMaterial({
                map: videoTexture,
                side: THREE.DoubleSide
              });
              child.visible = true;
            } 
            // 2. Hide obscuring glass/touch panel
            else if (nameUpper.includes('TOUCH PANEL') || nameUpper.includes('LCD BRACKET COVER')) {
              child.visible = false;
            }
            // 3. USER SPECIFIED #B1B1B1 PARTS (Rotary Knob: Mesh_243, M12 NUT; Back Screw; Kickstand Fold Bar)
            else if (
              child.name === 'Mesh_243' || 
              nameUpper.includes('243') ||
              nameUpper.includes('POWER') || 
              nameUpper.includes('SWITCH') || 
              nameUpper.includes('STAND ARM') || 
              nameUpper.includes('STAND CROSS') || 
              nameUpper.includes('STAND') ||
              nameUpper.includes('STS') || 
              nameUpper.includes('PIPE') || 
              nameUpper.includes('SCREW') || 
              nameUpper.includes('INSERT') || 
              nameUpper.includes('M2.5') || 
              nameUpper.includes('M3') || 
              nameUpper.includes('M4') || 
              nameUpper.includes('M12')
            ) {
              if (child.material) {
                child.material = child.material.clone();
                // User Specified Color: #B1B1B1 (0xB1B1B1)
                child.material.color = new THREE.Color(0xb1b1b1);
                child.material.metalness = 0.85;
                child.material.roughness = 0.25;
              }
            }
            // 4. SIDE BATTERY DOOR PANEL (Deep Jet Black #121417)
            else if (nameUpper.includes('BATTERY DOOR HINGE COVER')) {
              if (child.material) {
                child.material = child.material.clone();
                child.material.color = new THREE.Color(0x121417);
                child.material.metalness = 0.20;
                child.material.roughness = 0.65;
              }
            }
            // 5. RUBBER CORNER CAPS & MARGIN COVERS (Deep Matte Black #0B0C0E)
            else if (
              nameUpper.includes('COVER') || 
              nameUpper.includes('CAP') || 
              nameUpper.includes('RUBBER') || 
              nameUpper.includes('PROBE COVER') || 
              nameUpper.includes('BATTERY COVER') || 
              nameUpper.includes('IO COVER')
            ) {
              if (child.material) {
                child.material = child.material.clone();
                child.material.color = new THREE.Color(0x0b0c0e);
                child.material.metalness = 0.10;
                child.material.roughness = 0.80;
              }
            }
            // 6. MAIN CHASSIS BODY (Deep Jet Black #121417)
            else if (child.material) {
              child.material = child.material.clone();
              child.material.color = new THREE.Color(0x121417);
              child.material.metalness = 0.20;
              child.material.roughness = 0.65;
            }
          }
        });

        scene.add(b3ModelGroup);

        // Hide loading bar seamlessly
        if (loadingBar) {
          loadingBar.style.opacity = '0';
          setTimeout(() => {
            loadingBar.style.display = 'none';
          }, 500);
        }
      },
      (xhr) => {},
      (error) => {
        console.error('Error loading B3 3D GLB model:', error);
      }
    );

    // Animation Loop with VideoTexture Frame Updates
    function animate() {
      requestAnimationFrame(animate);
      if (videoTexture && videoElem && !videoElem.paused) {
        videoTexture.needsUpdate = true;
      }
      controls.update();
      renderer.render(scene, camera);
    }
    animate();

    // Window Resize Handler
    window.addEventListener('resize', () => {
      if (!container) return;
      camera.aspect = container.clientWidth / container.clientHeight;
      camera.updateProjectionMatrix();
      renderer.setSize(container.clientWidth, container.clientHeight);
    });

    // Control Panel Handlers
    btnReset?.addEventListener('click', () => {
      controls.reset();
      camera.position.set(0, 0.02, 0.45);
      controls.target.set(0, 0, 0);
      if (b3ModelGroup) {
        b3ModelGroup.rotation.set(0, 0, 0);
      }
      controls.update();
    });

    let isSpinning = true;
    btnSpin?.addEventListener('click', () => {
      isSpinning = !isSpinning;
      controls.autoRotate = isSpinning;
      if (txtSpin) txtSpin.textContent = isSpinning ? '⏸️ Pause Spin' : '▶️ Auto Spin';
    });

    let isVideoPlaying = true;
    btnVideo?.addEventListener('click', () => {
      if (!videoElem) return;
      if (isVideoPlaying) {
        videoElem.pause();
        isVideoPlaying = false;
        if (txtVideo) txtVideo.textContent = '▶️ Play Video';
      } else {
        videoElem.play();
        isVideoPlaying = true;
        if (txtVideo) txtVideo.textContent = '🎬 Video On';
      }
    });

    btnFullscreen?.addEventListener('click', () => {
      if (document.fullscreenElement) {
        document.exitFullscreen();
      } else {
        container.requestFullscreen().catch(err => console.warn('Fullscreen error:', err));
      }
    });
  });
</script>
