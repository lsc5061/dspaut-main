	<script>
		// Client-side Tab Switchers & Console Simulators Script
		
		// 1. Hero Console Simulator
		const consoleBtns = document.querySelectorAll('.console-tab-btn');
		const consoleImg = document.getElementById('hero-console-img') as HTMLImageElement;

		consoleBtns.forEach(btn => {
			btn.addEventListener('click', () => {
				const targetImgPath = btn.getAttribute('data-img');
				if (consoleImg && targetImgPath) {
					consoleImg.style.opacity = '0';
					setTimeout(() => {
						consoleImg.src = targetImgPath;
						consoleImg.style.opacity = '1';
					}, 150);
				}

				consoleBtns.forEach(b => {
					b.classList.remove('bg-slate-900', 'text-primary-cyan', 'border-primary-cyan/30');
					b.classList.add('text-slate-400', 'border-transparent', 'hover:text-white');
				});
				btn.classList.add('bg-slate-900', 'text-primary-cyan', 'border-primary-cyan/30');
				btn.classList.remove('text-slate-400', 'border-transparent', 'hover:text-white');
			});
		});

		// 2. Feature 1 Tab Switcher
		const tabButtons = document.querySelectorAll('.tab-btn');
		const tabContents = document.querySelectorAll('.tab-content');

		tabButtons.forEach(btn => {
			btn.addEventListener('click', () => {
				const targetTab = btn.getAttribute('data-tab');

				tabButtons.forEach(b => {
					b.classList.remove('bg-primary-cyan', 'text-slate-950', 'shadow-sm');
					b.classList.add('text-slate-600', 'hover:text-slate-900', 'hover:bg-slate-300/40');
				});
				btn.classList.add('bg-primary-cyan', 'text-slate-950', 'shadow-sm');
				btn.classList.remove('text-slate-600', 'hover:text-slate-900', 'hover:bg-slate-300/40');

				tabContents.forEach(content => {
					if (content.getAttribute('id') === `tab-${targetTab}`) {
						content.classList.remove('hidden');
					} else {
						content.classList.add('hidden');
					}
				});
			});
		});

		// 3. Feature 3 TFM Gallery Switcher
		const tfmBtns = document.querySelectorAll('.tfm-tab-btn');
		const tfmImg = document.getElementById('tfm-gallery-img') as HTMLImageElement;

		tfmBtns.forEach(btn => {
			btn.addEventListener('click', () => {
				const targetImgPath = btn.getAttribute('data-img');
				if (tfmImg && targetImgPath) {
					tfmImg.style.opacity = '0';
					setTimeout(() => {
						tfmImg.src = targetImgPath;
						tfmImg.style.opacity = '1';
					}, 150);
				}

				tfmBtns.forEach(b => {
					b.classList.remove('bg-primary-cyan', 'text-slate-950', 'border-primary-cyan');
					b.classList.add('text-slate-400', 'border-slate-800', 'hover:text-white');
				});
				btn.classList.add('bg-primary-cyan', 'text-slate-950', 'border-primary-cyan');
				btn.classList.remove('text-slate-400', 'border-slate-800', 'hover:text-white');
			});
		});
	</script>

	<!-- Contact CTA Form Section -->
