---
import Layout from '../../../layouts/Layout.astro';

const portalUrl = import.meta.env.PUBLIC_PORTAL_URL || "https://support.dspaut.com";
const web3FormsKey = import.meta.env.PUBLIC_WEB3FORMS_KEY || "YOUR_ACCESS_KEY_HERE";
---

<Layout 
	title="DSViewer | 오프라인 위상배열 초음파(PAUT) 데이터 분석 소프트웨어" 
	description="(주)성산연구소의 오프라인 데이터 분석 소프트웨어 DSViewer를 소개합니다. 고해상도 A/B/C/D/S-scan 다중 뷰어, 정밀 결함 사이징 및 오프라인 교정 기능 지원."
	lang="ko"
>
	<!-- Software Hero Section -->
	<section class="relative bg-[#0C1929] text-white overflow-hidden py-20 sm:py-28 border-b border-slate-800">
		<div class="absolute -top-40 left-1/4 w-96 h-96 bg-primary-cyan/15 rounded-full blur-[100px] pointer-events-none"></div>
		<div class="absolute -bottom-40 right-1/4 w-96 h-96 bg-blue-600/10 rounded-full blur-[100px] pointer-events-none"></div>
		
		<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
			<div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-center">
				<!-- Hero Left Content -->
				<div class="lg:col-span-7 space-y-6">
					<div class="inline-flex items-center space-x-2 bg-slate-900 border border-slate-800 rounded-full px-3.5 py-1 text-sm text-primary-cyan font-semibold tracking-wide">
						<span>PC 전용 오프라인 데이터 분석 SW</span>
					</div>
					<h1 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold tracking-tight font-display leading-tight">
						DSViewer<br/>
						<span class="text-transparent bg-clip-text bg-gradient-to-r from-primary-cyan to-blue-400">오프라인 데이터 분석</span>
					</h1>
					<p class="text-lg text-slate-200 leading-relaxed max-w-2xl">
						DSViewer는 현장에서 획득 및 저장 완료된 초음파 검사 로데이터 파일(.dat, .raw)을 분석하는 PC 전용 소프트웨어입니다. 자유롭게 조율 가능한 다중 스캔 뷰어(A/B/C/D/S-Scan), 정밀 크로스하어 커서 측정, 부식 매핑 전용 컬러 컨트롤 기능들을 활용하여 검사 데이터를 신속하고 완벽하게 시각화 및 문서화합니다.
					</p>
					
					<div class="flex flex-wrap gap-3 pt-4">
						<a href={portalUrl} target="_blank" class="px-6 py-3.5 text-sm font-bold text-slate-900 bg-primary-cyan hover:bg-cyan-400 rounded-lg shadow-lg shadow-primary-cyan/20 transition-all duration-200 hover:-translate-y-0.5">
							DSViewer 무료 다운로드 (자료실)
						</a>
						<a href={portalUrl} target="_blank" class="px-6 py-3.5 text-sm font-bold text-slate-300 border border-slate-700 hover:border-slate-500 hover:text-white rounded-lg transition-all duration-200 hover:-translate-y-0.5">
							기술 지원 포털 이동
						</a>
					</div>
				</div>
				
				<!-- Hero Right Image (Interactive Software Console) -->
				<div class="lg:col-span-5 relative flex flex-col items-center justify-center space-y-4">
					<div class="absolute w-80 h-80 bg-primary-cyan/15 rounded-full blur-[60px]"></div>
					<!-- UI Mockup Visual -->
					<div class="relative bg-slate-950 border border-slate-800 rounded-2xl p-4 shadow-2xl overflow-hidden group w-full max-w-lg aspect-[4/3] flex items-center justify-center">
						<img 
							id="hero-console-img"
							src="/assets/img/software/dsviewer/Corrosion_1.png" 
							alt="DSViewer 분석 인터페이스" 
							class="w-full h-full object-contain rounded-lg transition-opacity duration-300"
						/>
					</div>
					<!-- Console Tabs selector -->
					<div class="grid grid-cols-2 gap-2 pt-3 relative z-10 w-full max-w-lg">
						<button 
							class="console-tab-btn px-3.5 py-2.5 text-sm font-semibold rounded-lg border bg-slate-900 text-primary-cyan border-primary-cyan/30 cursor-pointer transition-all text-center w-full" 
							data-img="/assets/img/software/dsviewer/Corrosion_1.png"
						>
							부식 C-스캔
						</button>
						<button 
							class="console-tab-btn px-3.5 py-2.5 text-sm font-semibold rounded-lg border text-slate-400 border-slate-800 hover:text-white cursor-pointer transition-all text-center w-full" 
							data-img="/assets/img/software/dsviewer/Weld_Sepcimen.png"
						>
							용접 분석
						</button>
						<button 
							class="console-tab-btn px-3.5 py-2.5 text-sm font-semibold rounded-lg border text-slate-400 border-slate-800 hover:text-white cursor-pointer transition-all text-center w-full" 
							data-img="/assets/img/software/dsviewer/DSViewer_Channel_Group.png"
						>
							다채널 계측
						</button>
						<button 
							class="console-tab-btn px-3.5 py-2.5 text-sm font-semibold rounded-lg border text-slate-400 border-slate-800 hover:text-white cursor-pointer transition-all text-center w-full" 
							data-img="/assets/img/software/dsviewer/Measurement .png"
						>
							커서 및 게이트
						</button>
					</div>
				</div>
			</div>
		</div>
	</section>

	<!-- Quick Spec Highlights -->
	<section class="bg-slate-900 border-b border-slate-800 py-10 text-slate-300">
		<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
			<div class="grid grid-cols-2 md:grid-cols-4 gap-6 text-center">
				<div class="space-y-1">
					<span class="block text-2xl font-bold text-white">원시 로데이터</span>
					<span class="text-sm uppercase tracking-wider text-slate-400 font-sans font-semibold">드래그 앤 드롭 파일 로드</span>
				</div>
				<div class="w-px h-12 bg-slate-800 hidden md:block self-center mx-auto"></div>
				<div class="space-y-1">
					<span class="block text-2xl font-bold text-white">데이터 바</span>
					<span class="text-sm uppercase tracking-wider text-slate-400 font-sans font-semibold">스캔 위치별 데이터 실시간 동기화</span>
				</div>
				<div class="w-px h-12 bg-slate-800 hidden md:block self-center mx-auto"></div>
				<div class="space-y-1">
					<span class="block text-2xl font-bold text-white">정밀 사이징</span>
					<span class="text-sm uppercase tracking-wider text-slate-400 font-sans font-semibold">결함 크기 및 깊이 측정</span>
				</div>
				<div class="w-px h-12 bg-slate-800 hidden md:block self-center mx-auto"></div>
				<div class="space-y-1">
					<span class="block text-2xl font-bold text-white">다중 스캔 뷰</span>
					<span class="text-sm uppercase tracking-wider text-slate-400 font-sans font-semibold">다차원 초음파 신호 동시 분석</span>
				</div>
			</div>
		</div>
	</section>

	<!-- Detailed Software Features -->
	<section class="py-20 bg-slate-50 border-b border-slate-200">
		<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 space-y-28">
			
			<!-- Feature 1: 2D C-Scan Viewing & Corrosion Mapping -->
			<div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-center">
				<div class="lg:col-span-6 relative order-last lg:order-first">
					<div class="bg-slate-950 border border-slate-800 rounded-2xl p-4 shadow-xl">
						<img 
							src="/assets/img/software/dsviewer/Corrosion_1.png" 
							alt="오프라인 고해상도 C-스캔 및 부식 매핑 분석" 
							class="w-full h-auto object-contain rounded-lg"
						/>
					</div>
				</div>
				<div class="lg:col-span-6 space-y-6 sm:space-y-7.5">
					<div>
						<span class="text-sm sm:text-base font-bold font-sans text-primary-cyan bg-slate-900 px-3 py-1.5 rounded inline-block mb-2">DATA VISUALIZATION</span>
					</div>
					<h2 class="text-3xl sm:text-4xl lg:text-[2.5rem] leading-tight font-extrabold text-slate-900 tracking-tight font-display">
						오프라인 2D C-스캔 및 부식 지형 매핑
					</h2>
					<p class="text-slate-850 leading-relaxed text-base sm:text-[17px]">
						현장 장비에서 획득하여 USB 등으로 복사된 원시 로데이터 파일(.dat, .raw)을 PC로 가져와 마우스 드래그 앤 드롭만으로 초고속 로딩합니다. 신호 진폭(Amplitude) 또는 전파 시간(Time of Flight) 값을 기준으로 다채로운 2D 컬러 맵을 시각화하여, 부식 영역의 지형도 분석이나 소재 내부 결함을 한눈에 분석합니다.
					</p>
					<p class="text-slate-850 leading-relaxed text-base sm:text-[17px]">
						부식 검사(Corrosion)에 적합한 전용 컬러 맵 분석을 제공합니다. 진폭(A%) 또는 위치(A/, B/, A/-B/, Position)를 기반으로 컬러 코딩 방식을 전환할 수 있으며, 색상 변화 기준 범위(Min/Max, Linear/Reverse)를 미세 조정하여 강도나 두께의 미세한 편차를 시각적으로 극대화하여 도출할 수 있습니다.
					</p>
					<ul class="space-y-4 text-base sm:text-[17px] text-slate-900 font-medium pt-2">
						<li class="flex items-start space-x-3">
							<span class="text-primary-cyan text-xl leading-none">✔</span>
							<span>기가바이트 단위의 대용량 초음파 로데이터 파일도 지연 없이 렌더링</span>
						</li>
						<li class="flex items-start space-x-3">
							<span class="text-primary-cyan text-xl leading-none">✔</span>
							<span>부식 정밀 측정을 위한 Corrosion 전용 컬러 팔레트 및 대비 최적화 제어</span>
						</li>
						<li class="flex items-start space-x-3">
							<span class="text-primary-cyan text-xl leading-none">✔</span>
							<span>데이터 획득 장비의 원시 파일 헤더 매개변수 정보 자동 획득 및 재해석</span>
						</li>
					</ul>
				</div>
			</div>

			<!-- Feature 2: Multi-View Layout & 5-Axis Rulers -->
			<div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-center">
				<div class="lg:col-span-6 space-y-6 sm:space-y-7.5">
					<div>
						<span class="text-sm sm:text-base font-bold font-sans text-primary-cyan bg-slate-900 px-3 py-1.5 rounded inline-block mb-2">SCAN LAYOUTS</span>
					</div>
					<h2 class="text-3xl sm:text-4xl lg:text-[2.5rem] leading-tight font-extrabold text-slate-900 tracking-tight font-display">
						다중 스캔 뷰 레이아웃 및 5가지 눈금자
					</h2>
					<p class="text-slate-850 leading-relaxed text-base sm:text-[17px]">
						A-scan, B-scan, C-scan, D-scan, 그리고 부채꼴 스윕 영상인 S-scan(Sectorial) 화면을 동시에 검토할 수 있는 다중 스캔 디스플레이 대시보드를 제공합니다. 레이아웃 배치는 사용자의 분석 편의에 맞춰 자유롭게 조절(A-B-C 레이아웃 등)할 수 있어 현장 계측과 오프라인 연구에 최적의 환경을 보장합니다.
					</p>
					<p class="text-slate-850 leading-relaxed text-base sm:text-[17px]">
						결함의 물리적 위치 좌표를 오차 없이 식별하기 위해 전용 눈금자(Rulers)가 각 축별로 개별 색상 코딩되어 제공됩니다: 스캔 축(Scan - Blue), 인덱스 축(Index - Green), 진폭 축(Amplitude - Yellow), 초음파 음로 거리(Sound Path - Pink), 실제 수직 깊이(True Depth - Purple).
					</p>
					<ul class="space-y-4 text-base sm:text-[17px] text-slate-900 font-medium pt-2">
						<li class="flex items-start space-x-3">
							<span class="text-primary-cyan text-xl leading-none">✔</span>
							<span>A / B / C / D / S-scan 등의 다차원 초음파 신호 복합 오버레이 및 시각화</span>
						</li>
						<li class="flex items-start space-x-3">
							<span class="text-primary-cyan text-xl leading-none">✔</span>
							<span>실시간 5축 눈금자 컬러 코딩 시스템으로 분석 에러와 계산 과정 완전 배제</span>
						</li>
						<li class="flex items-start space-x-3">
							<span class="text-primary-cyan text-xl leading-none">✔</span>
							<span>양면 듀얼 및 멀티 채널 프로브 데이터의 채널별 데이터 정렬 지원</span>
						</li>
					</ul>
				</div>
				<div class="lg:col-span-6 relative">
					<div class="bg-slate-950 border border-slate-800 rounded-2xl p-4 shadow-xl">
						<img 
							src="/assets/img/software/dsviewer/DSViewer_Channel_Group.png" 
							alt="다중 뷰 레이아웃 및 다채널 데이터 모니터링" 
							class="w-full h-auto object-contain rounded-lg"
						/>
					</div>
				</div>
			</div>

			<!-- Feature 3: Precision Flaw Sizing & 3-Gate Analysis -->
			<div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-center">
				<div class="lg:col-span-6 relative order-last lg:order-first">
					<div class="bg-slate-950 border border-slate-800 rounded-2xl p-4 shadow-xl">
						<img 
							src="/assets/img/software/dsviewer/Measurement .png" 
							alt="정밀 커서 측정 및 3개 게이트 제어 화면" 
							class="w-full h-auto object-contain rounded-lg"
						/>
					</div>
				</div>
				<div class="lg:col-span-6 space-y-6 sm:space-y-7.5">
					<div>
						<span class="text-sm sm:text-base font-bold font-sans text-primary-cyan bg-slate-900 px-3 py-1.5 rounded inline-block mb-2">MEASUREMENT & TOLERANCE</span>
					</div>
					<h2 class="text-3xl sm:text-4xl lg:text-[2.5rem] leading-tight font-extrabold text-slate-900 tracking-tight font-display">
						정밀 결함 사이징 및 3-Gate 수치 정밀 분석
					</h2>
					<p class="text-slate-850 leading-relaxed text-base sm:text-[17px]">
						화면상에 내장된 수평/수직 기준선(Reference) 및 측정선(Measurement) 크로스하어 커서를 조작하여, 검출된 결함의 물리적인 크기(가로 폭 및 높이)를 화면상에서 정량적으로 즉석 사이징합니다.
					</p>
					<p class="text-slate-850 leading-relaxed text-base sm:text-[17px]">
						신호 모니터링을 위한 독립적인 게이트(Gate A, B, I) 3개를 제공합니다. C-scan 상에서 게이트 영역 내의 최대 진폭 데이터를 투영하여 볼 수 있으며, 내장된 Measure Tool을 통해 게이트별 진폭(A%, B%, I%), 음로 거리(SA, SB, SI), 깊이(DA, DB, DI), 기준 투영 거리(PA, PB, PI), 그리고 두 게이트 간의 상대적 편차(Δ) 값을 소수점 단위로 자동 산출합니다.
					</p>
					<ul class="space-y-4 text-base sm:text-[17px] text-slate-900 font-medium pt-2">
						<li class="flex items-start space-x-3">
							<span class="text-primary-cyan text-xl leading-none">✔</span>
							<span>크로스하어 마우스 포인팅 드래그로 결함 위치와 크기를 정밀 측정</span>
						</li>
						<li class="flex items-start space-x-3">
							<span class="text-primary-cyan text-xl leading-none">✔</span>
							<span>독립적인 A / B / I 인터페이스 게이트 및 트리거 설정</span>
						</li>
						<li class="flex items-start space-x-3">
							<span class="text-primary-cyan text-xl leading-none">✔</span>
							<span>%, SA/SB/SI, DA/DB/DI, 편차 정보가 포함된 전용 수치 측정 계측기 기능 제공</span>
						</li>
					</ul>
				</div>
			</div>

			<!-- Feature 4: Dynamic Zoom & Offline Calibration -->
			<div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-center">
				<div class="lg:col-span-6 space-y-6 sm:space-y-7.5">
					<div>
						<span class="text-sm sm:text-base font-bold font-sans text-primary-cyan bg-slate-900 px-3 py-1.5 rounded inline-block mb-2">CALIBRATION & DATA EXPORT</span>
					</div>
					<h2 class="text-3xl sm:text-4xl lg:text-[2.5rem] leading-tight font-extrabold text-slate-900 tracking-tight font-display">
						화면 줌 제어 및 분석 로데이터 오프라인 교정
					</h2>
					<p class="text-slate-850 leading-relaxed text-base sm:text-[17px]">
						미세 결함 집중 구역을 분석하기 위해 Zoom mode를 클릭하고 마우스 드래그를 통해 즉시 화면을 줌 확대합니다. 또한 마우스 휠 조작을 통한 유기적인 확대/축소 및 Ctrl 키 드래그 이동을 기본 지원하여 상세 판독의 효율성을 극대화합니다.
					</p>
					<p class="text-slate-850 leading-relaxed text-base sm:text-[17px]">
						원시 파일을 손상시키지 않고 분석 단계에서 보정값을 보조할 수 있습니다. 오프라인 상태에서 Wedge delay, 음속(Velocity), TOFD 동기화 등 핵심 교정 수치(Calibration)를 재입력하면, 이미지를 가공하지 않고 눈금자(Ruler) 배율에만 실시간 보정값을 매핑합니다. 분석 완료 후 각 스캔 창 화면을 단 한 번의 클릭으로 개별 PNG 이미지 파일로 저장(캡처)하여 문서화에 즉시 활용할 수 있습니다.
					</p>
					<ul class="space-y-4 text-base sm:text-[17px] text-slate-900 font-medium pt-2">
						<li class="flex items-start space-x-3">
							<span class="text-primary-cyan text-xl leading-none">✔</span>
							<span>마우스 휠 조작 및 드래그 줌 확대 기능으로 정밀 판독 지원</span>
						</li>
						<li class="flex items-start space-x-3">
							<span class="text-primary-cyan text-xl leading-none">✔</span>
							<span>Wedge delay, 음속(Velocity), TOFD 동기화 등 오프라인 보정값 반영 교정 툴</span>
						</li>
						<li class="flex items-start space-x-3">
							<span class="text-primary-cyan text-xl leading-none">✔</span>
							<span>각 스캔 보기 화면별 개별 PNG 이미지 추출 및 파일 저장</span>
						</li>
					</ul>
				</div>
				<div class="lg:col-span-6 relative">
					<div class="bg-slate-950 border border-slate-800 rounded-2xl p-4 shadow-xl">
						<img 
							src="/assets/img/software/dsviewer/Zoom.png" 
							alt="오프라인 화면 줌 및 교정 제어 인터페이스" 
							class="w-full h-auto object-contain rounded-lg"
						/>
					</div>
				</div>
			</div>

		</div>
	</section>

	<!-- Contact CTA Form Section -->
	<section id="contact-quote" class="py-20 bg-slate-900 text-white border-t border-slate-800 relative">
		<div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 space-y-8 relative z-10 text-center">
			<h2 class="text-3xl font-extrabold font-display text-white">
				DSViewer 솔루션 도입 문의
			</h2>
			<p class="text-slate-400 text-sm max-w-xl mx-auto">
				DSViewer 라이선스 도입 견적 상담이나 기술 영업 지원이 필요하시면 정보를 입력해 주십시오. 담당 엔지니어가 신속히 답변 드리겠습니다.
			</p>
			
			<div class="bg-slate-950 border border-slate-850 rounded-2xl p-8 text-left max-w-xl mx-auto shadow-2xl">
				<form action="https://api.web3forms.com/submit" method="POST" class="space-y-4">
					<input type="hidden" name="access_key" value={web3FormsKey} />
					<input type="hidden" name="subject" value="DSPAUT DSViewer Website 문의" />
					<input type="hidden" name="from_name" value="DSPAUT Main Website" />
					<input type="checkbox" name="botcheck" class="hidden" style="display: none;" />

					<div class="grid grid-cols-2 gap-4">
						<div class="space-y-1">
							<label for="name" class="block text-sm uppercase font-bold text-slate-400 font-sans">성함</label>
							<input type="text" name="name" id="name" required class="w-full bg-slate-900 border border-slate-800 rounded px-3 py-2 text-sm text-white focus:outline-none focus:border-primary-cyan" />
						</div>
						<div class="space-y-1">
							<label for="company" class="block text-sm uppercase font-bold text-slate-400 font-sans">회사명</label>
							<input type="text" name="company" id="company" class="w-full bg-slate-900 border border-slate-800 rounded px-3 py-2 text-sm text-white focus:outline-none focus:border-primary-cyan" />
						</div>
					</div>
					
					<div class="space-y-1">
						<label for="email" class="block text-sm uppercase font-bold text-slate-400 font-sans">이메일 주소</label>
						<input type="email" name="email" id="email" required class="w-full bg-slate-900 border border-slate-800 rounded px-3 py-2 text-sm text-white focus:outline-none focus:border-primary-cyan" />
					</div>

					<div class="space-y-1">
						<label for="message" class="block text-sm uppercase font-bold text-slate-400 font-sans">문의 사항 및 요구 조건</label>
						<textarea name="message" id="message" rows="4" placeholder="도입 수량, 분석 대상 로데이터 형식, 또는 구체적인 요구 사항을 입력해 주십시오..." class="w-full bg-slate-900 border border-slate-800 rounded px-3 py-2 text-sm text-white focus:outline-none focus:border-primary-cyan"></textarea>
					</div>

					<button type="submit" class="w-full bg-primary-cyan text-slate-950 font-bold py-3.5 rounded hover:bg-cyan-400 text-sm transition-colors tracking-wide uppercase shadow-md shadow-primary-cyan/20">
						DSViewer 도입 문의 제출
					</button>
				</form>
			</div>
		</div>
	</section>

	<script>
		// Client-side Tab Switcher for Hero Simulator
		const consoleBtns = document.querySelectorAll('.console-tab-btn');
		const consoleImg = document.getElementById('hero-console-img') as HTMLImageElement;

		consoleBtns.forEach(btn => {
			btn.addEventListener('click', () => {
				const targetImgPath = btn.getAttribute('data-img');
				if (consoleImg && targetImgPath) {
					consoleImg.style.opacity = '0';
					setTimeout(() => {
						consoleImg.src = targetImgPath;
						consoleImg.style.opacity = '1';
					}, 150);
				}

				consoleBtns.forEach(b => {
					b.classList.remove('bg-slate-900', 'text-primary-cyan', 'border-primary-cyan/30');
					b.classList.add('text-slate-400', 'border-slate-800', 'hover:text-white');
				});
				btn.classList.add('bg-slate-900', 'text-primary-cyan', 'border-primary-cyan/30');
				btn.classList.remove('text-slate-400', 'border-slate-800', 'hover:text-white');
			});
		});
	</script>
</Layout>
