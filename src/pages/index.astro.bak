---
import Layout from '../layouts/Layout.astro';
---

<Layout 
	title="DSPAUT | Phased Array Ultrasonic NDT Systems & Software"
	description="DEEPSOUND NDT solutions by SEONGSANLAB. Discover premium portable PAUT instruments, automated system scanners, and advanced acquisition/analysis software."
	lang="en"
>
	<!-- Hero Section with Deep Navy Dark Theme and Neon Cyan Glows -->
	<section class="relative bg-[#0C1929] text-white overflow-hidden py-24 sm:py-32 border-b border-slate-800">
		<!-- Glowing Background Accents -->
		<div class="absolute top-1/4 left-1/4 -translate-x-1/2 -translate-y-1/2 w-96 h-96 bg-primary-cyan/10 rounded-full blur-3xl pointer-events-none"></div>
		<div class="absolute bottom-10 right-1/4 w-[500px] h-[500px] bg-blue-600/10 rounded-full blur-3xl pointer-events-none"></div>
		
		<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
			<div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-8 items-center">
				
				<!-- Hero Left Content -->
				<div class="lg:col-span-7 space-y-8">
					<div class="inline-flex items-center space-x-2 bg-slate-900 border border-slate-800 rounded-full px-3 py-1 text-xs text-primary-cyan font-semibold tracking-wide">
						<span>Ultrasonic NDT Brand: DEEPSOUND</span>
					</div>
					
					<h1 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold tracking-tight font-display leading-tight">
						Precision PAUT Hardware & <span class="text-transparent bg-clip-text bg-gradient-to-r from-primary-cyan to-blue-400">Real-time Acquisition & Analysis Software</span>
					</h1>
					
					<p class="text-lg text-slate-300 leading-relaxed max-w-2xl">
						Developed by SEONGSANLAB, DEEPSOUND delivers portable Phased Array UT, multi-channel rack scanners, and specialized defect acquisition/analysis software for global NDT technicians.
					</p>
					
					<!-- Simulated Pagefind Document Search Bar -->
					<div class="max-w-lg">
						<form class="relative group" action="/resources/">
							<div class="absolute -inset-0.5 bg-gradient-to-r from-primary-cyan to-blue-500 rounded-lg blur opacity-30 group-hover:opacity-60 transition duration-300"></div>
							<div class="relative bg-slate-950/90 border border-slate-800 rounded-lg flex items-center p-1.5 pl-4">
								<svg class="h-5 w-5 text-slate-400 mr-2 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
									<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
								</svg>
								<input 
									type="text" 
									name="q"
									placeholder="Search Manuals, Datasheets, Certificates, or Software..." 
									class="bg-transparent text-sm text-white placeholder-slate-500 w-full focus:outline-none pr-4"
								/>
								<button type="submit" class="bg-primary-cyan text-slate-950 text-xs font-bold px-4 py-2 rounded-md hover:bg-cyan-400 transition-all flex-shrink-0">
									Find Docs
								</button>
							</div>
						</form>
						<p class="text-xs text-slate-400 mt-2 ml-1">
							Quick search: <span class="text-primary-cyan/80">P5 Manual</span>, <span class="text-primary-cyan/80">DSVision Update</span>, <span class="text-primary-cyan/80">ISO 9001</span>
						</p>
					</div>
					
					<!-- Primary Action Buttons -->
					<div class="flex flex-wrap gap-4 pt-2">
						<a href="#products" class="px-6 py-3.5 text-sm font-bold text-slate-950 bg-primary-cyan hover:bg-[#00cbe6] rounded-md shadow-lg transition-all duration-200">
							Explore Products
						</a>
						<a href="/resources/" class="px-6 py-3.5 text-sm font-bold text-white border border-slate-700 hover:border-slate-500 rounded-md hover:bg-slate-900 transition-all duration-200">
							Technical Resources
						</a>
					</div>
				</div>
				
				<!-- Hero Right Visual (Hardware & Software 3D Layered Mocks) -->
				<div class="lg:col-span-5 relative flex justify-center items-center">
					<!-- Radial glowing backing -->
					<div class="absolute w-80 h-80 bg-primary-cyan/15 rounded-full blur-2xl"></div>
					
					<!-- 3D layered glass container -->
					<div class="relative w-full max-w-md aspect-square bg-slate-950/40 border border-slate-800/80 rounded-2xl p-8 backdrop-blur-md shadow-2xl flex flex-col justify-between overflow-hidden">
						<!-- Scanner/Hardware Graphic Simulated via CSS -->
						<div class="absolute -right-16 -bottom-16 w-64 h-64 rounded-full border border-primary-cyan/20 flex items-center justify-center pointer-events-none">
							<div class="w-48 h-48 rounded-full border border-primary-cyan/10 flex items-center justify-center">
								<div class="w-32 h-32 rounded-full border border-primary-cyan/5"></div>
							</div>
						</div>
						
						<!-- Simulated Hardware Card -->
						<div class="relative bg-slate-900/90 border border-slate-700/50 rounded-xl p-4 shadow-lg transform -rotate-2 hover:rotate-0 transition-transform duration-300 space-y-3 z-10">
							<div class="flex justify-between items-center">
								<span class="text-[10px] font-bold text-primary-cyan uppercase tracking-wider">NDT INSTRUMENT</span>
								<span class="text-[10px] px-2 py-0.5 bg-slate-800 text-slate-400 rounded-full font-mono">12.1" LCD</span>
							</div>
							<h3 class="text-base font-bold text-white">DEEPSOUND P5</h3>
							<p class="text-xs text-slate-400 leading-snug">12.1-inch high-resolution display with ultra-fast boot-up and real-time operations, ensuring rapid flaw detection.</p>
							<div class="flex gap-2">
								<span class="text-[10px] bg-slate-800 text-slate-300 px-2 py-0.5 rounded">PAUT</span>
								<span class="text-[10px] bg-slate-800 text-slate-300 px-2 py-0.5 rounded">TOFD</span>
								<span class="text-[10px] bg-slate-800 text-slate-300 px-2 py-0.5 rounded">Multi-Group</span>
							</div>
						</div>
						
						<!-- Simulated Software Acquisiton Screen Card -->
						<div class="relative bg-slate-900/90 border border-slate-700/50 rounded-xl p-4 shadow-lg transform translate-x-8 -translate-y-4 rotate-3 hover:rotate-0 transition-transform duration-300 space-y-3 z-20">
							<div class="flex justify-between items-center">
								<span class="text-[10px] font-bold text-[#3B82F6] uppercase tracking-wider">ACQUISITION SOFTWARE</span>
								<span class="text-[10px] text-green-400 flex items-center space-x-1">
									<span class="w-1.5 h-1.5 bg-green-400 rounded-full animate-ping"></span>
									<span>Active</span>
								</span>
							</div>
							<h3 class="text-base font-bold text-white">DSVision Acquire</h3>
							<!-- Defect Plot Mock -->
							<div class="h-16 w-full bg-slate-950 rounded border border-slate-800 flex items-center justify-between px-3 overflow-hidden font-mono text-[9px] text-primary-cyan/80">
								<div class="space-y-1">
									<div>THICKNESS: 24.5mm</div>
									<div>AMP: 88% FSH</div>
								</div>
								<div class="flex items-end space-x-0.5 h-10 w-24">
									<div class="bg-[#3B82F6]/40 w-2 h-3"></div>
									<div class="bg-[#3B82F6]/60 w-2 h-6"></div>
									<div class="bg-primary-cyan w-2 h-9"></div>
									<div class="bg-[#3B82F6]/60 w-2 h-4"></div>
									<div class="bg-[#3B82F6]/40 w-2 h-2"></div>
								</div>
							</div>
						</div>
					</div>
				</div>
				
			</div>
		</div>
	</section>

	<!-- Trust Bar / Global Authority Indicators -->
	<section class="bg-slate-900 border-b border-slate-800 py-6 text-slate-400">
		<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
			<div class="grid grid-cols-1 sm:grid-cols-3 gap-6 text-center">
				<div class="pt-4 sm:pt-0">
					<p class="text-2xl font-bold text-white">Proprietary R&D</p>
					<p class="text-xs uppercase tracking-wider text-slate-500 mt-1 font-semibold">In-House H/W & S/W Dev</p>
				</div>
				<div class="pt-4 sm:pt-0">
					<p class="text-2xl font-bold text-white">Advanced NDT</p>
					<p class="text-xs uppercase tracking-wider text-slate-500 mt-1 font-semibold">High-Performance PAUT & TOFD</p>
				</div>
				<div class="pt-4 sm:pt-0">
					<p class="text-2xl font-bold text-white">Dedicated Support</p>
					<p class="text-xs uppercase tracking-wider text-slate-500 mt-1 font-semibold">Custom SDK & Technical Service</p>
				</div>
			</div>
		</div>
	</section>

	<!-- B2B Quick Navigation Links (Light Mode starts here) -->
	<section class="py-12 bg-slate-50 border-b border-slate-200">
		<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
			<div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-5 gap-4">
				{[
					{ title: "Equipment Specs", desc: "Compare Models", href: "/products/" },
					{ title: "Software suite", desc: "Acquisition & Analysis", href: "/software/" },
					{ title: "User Manuals", desc: "Technical Guides", href: "/resources/" },
					{ title: "Product Catalog", desc: "Latest PDF Brochure", href: "/resources/" },
					{ title: "Certifications", desc: "Compliance & Safety", href: "/resources/" }
				].map((item) => (
					<a href={item.href} class="bg-white border border-slate-200 rounded-lg p-4 hover:border-primary-cyan hover:shadow-md transition-all duration-200">
						<h3 class="text-sm font-bold text-slate-900">{item.title}</h3>
						<p class="text-xs text-slate-500 mt-1">{item.desc}</p>
					</a>
				))}
			</div>
		</div>
	</section>

	<!-- Featured NDT Products with Custom Specs Badge System -->
	<section id="products" class="py-24 bg-white scroll-mt-16">
		<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
			<div class="text-center max-w-3xl mx-auto space-y-4">
				<h2 class="text-3xl font-extrabold text-slate-900 tracking-tight font-display">
					DEEPSOUND Precision NDT Hardware Solutions
				</h2>
				<p class="text-slate-600 text-sm">
					From portable diagnostic instruments to high-channel integrated OEM boards, we deliver premium-grade hardware for high-reliability non-destructive testing.
				</p>
			</div>
			
			<!-- Part 1: Portable NDT Instruments -->
			<div class="mt-16 border-b border-slate-100 pb-4">
				<div class="flex items-center space-x-3">
					<span class="px-2.5 py-0.5 bg-slate-900 text-primary-cyan text-xs font-mono font-bold rounded">CATEGORY 01</span>
					<h3 class="text-lg font-bold text-slate-900">Portable PAUT & Ultrasonic Testing Instruments</h3>
				</div>
				<p class="text-sm text-slate-500 mt-1">Ultra-lightweight, high-performance portable instruments designed to detect flaws rapidly in extreme field conditions.</p>
			</div>

			<div class="grid grid-cols-1 md:grid-cols-3 gap-8 mt-8">
				<!-- P5 Card -->
				<div class="bg-slate-50 border border-slate-200 rounded-xl overflow-hidden hover:border-slate-300 hover:shadow-lg transition-all duration-300 flex flex-col justify-between">
					<div class="p-6 space-y-4">
						<div class="flex justify-between items-start">
							<div>
								<span class="text-xs font-bold text-primary-cyan bg-slate-900 px-2 py-0.5 rounded uppercase tracking-wider">Premium Model</span>
								<h3 class="text-xl font-bold text-slate-900 mt-2">DEEPSOUND P5</h3>
							</div>
						</div>
						<p class="text-sm text-slate-600 leading-relaxed">
							Features a 12.1-inch high-resolution display, ultra-fast boot-up speed, and rapid operation. It guarantees precise and quick flaw detection in extreme industrial environments.
						</p>
						
						<!-- Specs Badge Grid -->
						<div class="grid grid-cols-2 gap-2 pt-2">
							<div class="bg-white border border-slate-200 rounded p-2 text-center text-xs">
								<span class="block text-xs text-slate-400 uppercase font-mono">Display</span>
								<span class="font-bold text-slate-800 text-sm">12.1" LCD</span>
							</div>
							<div class="bg-white border border-slate-200 rounded p-2 text-center text-xs">
								<span class="block text-xs text-slate-400 uppercase font-mono">Channels</span>
								<span class="font-bold text-slate-800 text-sm">32/128PR</span>
							</div>
							<div class="bg-white border border-slate-200 rounded p-2 text-center text-xs">
								<span class="block text-xs text-slate-400 uppercase font-mono">Methods</span>
								<span class="font-bold text-slate-800 text-sm">PAUT + TOFD</span>
							</div>
							<div class="bg-white border border-slate-200 rounded p-2 text-center text-xs">
								<span class="block text-xs text-slate-400 uppercase font-mono">Software</span>
								<span class="font-bold text-slate-800 text-sm">DSVision Inc.</span>
							</div>
						</div>
					</div>
					<div class="p-6 bg-slate-100 border-t border-slate-200 flex justify-between items-center gap-4">
						<a href="/resources/" class="text-xs font-semibold text-slate-600 hover:text-slate-900">Download Catalog</a>
						<a href="/products/" class="px-4 py-2 text-xs font-bold text-slate-900 bg-primary-cyan rounded hover:bg-cyan-400 transition-colors">Details</a>
					</div>
				</div>

				<!-- B3 Card -->
				<div class="bg-slate-50 border border-slate-200 rounded-xl overflow-hidden hover:border-slate-300 hover:shadow-lg transition-all duration-300 flex flex-col justify-between">
					<div class="p-6 space-y-4">
						<div class="flex justify-between items-start">
							<div>
								<span class="text-xs font-bold text-slate-500 bg-slate-200 px-2 py-0.5 rounded uppercase tracking-wider">Best Value</span>
								<h3 class="text-xl font-bold text-slate-900 mt-2">DEEPSOUND B3</h3>
							</div>
						</div>
						<p class="text-sm text-slate-600 leading-relaxed">
							Features an ultra-lightweight design under 2.0kg (including battery) for ultimate portability. Extremely cost-effective while delivering a real-time acquisition engine fully compatible with the premium P5 model.
						</p>
						
						<!-- Specs Badge Grid -->
						<div class="grid grid-cols-2 gap-2 pt-2">
							<div class="bg-white border border-slate-200 rounded p-2 text-center text-xs">
								<span class="block text-xs text-slate-400 uppercase font-mono">Weight</span>
								<span class="font-bold text-slate-800 text-sm">&lt; 2.0kg</span>
							</div>
							<div class="bg-white border border-slate-200 rounded p-2 text-center text-xs">
								<span class="block text-xs text-slate-400 uppercase font-mono">Compatibility</span>
								<span class="font-bold text-slate-800 text-sm">100% P5 Compatible</span>
							</div>
							<div class="bg-white border border-slate-200 rounded p-2 text-center text-xs">
								<span class="block text-xs text-slate-400 uppercase font-mono">Portability</span>
								<span class="font-bold text-slate-800 text-sm">Ultra compact</span>
							</div>
							<div class="bg-white border border-slate-200 rounded p-2 text-center text-xs">
								<span class="block text-xs text-slate-400 uppercase font-mono">Value</span>
								<span class="font-bold text-slate-800 text-sm">High ROI</span>
							</div>
						</div>
					</div>
					<div class="p-6 bg-slate-100 border-t border-slate-200 flex justify-between items-center gap-4">
						<a href="/resources/" class="text-xs font-semibold text-slate-600 hover:text-slate-900">Download Datasheet</a>
						<a href="/products/" class="px-4 py-2 text-xs font-bold text-slate-900 bg-primary-cyan rounded hover:bg-cyan-400 transition-colors">Details</a>
					</div>
				</div>

				<!-- T3 Card -->
				<div class="bg-slate-50 border border-slate-200 rounded-xl overflow-hidden hover:border-slate-300 hover:shadow-lg transition-all duration-300 flex flex-col justify-between">
					<div class="p-6 space-y-4">
						<div class="flex justify-between items-start">
							<div>
								<span class="text-xs font-bold text-blue-600 bg-blue-100 px-2 py-0.5 rounded uppercase tracking-wider">Ultra-Lightweight</span>
								<h3 class="text-xl font-bold text-slate-900 mt-2">DEEPSOUND T3</h3>
							</div>
						</div>
						<p class="text-sm text-slate-600 leading-relaxed">
							Next-generation 0.9kg ultra-lightweight detector featuring a high-definition 7-inch touch screen. Designed for comfortable one-handed operation, with built-in dedicated TOFD testing solutions for tight spaces.
						</p>
						
						<!-- Specs Badge Grid -->
						<div class="grid grid-cols-2 gap-2 pt-2">
							<div class="bg-white border border-slate-200 rounded p-2 text-center text-xs">
								<span class="block text-xs text-slate-400 uppercase font-mono">Weight</span>
								<span class="font-bold text-slate-800 text-sm">0.9kg</span>
							</div>
							<div class="bg-white border border-slate-200 rounded p-2 text-center text-xs">
								<span class="block text-xs text-slate-400 uppercase font-mono">Display</span>
								<span class="font-bold text-slate-800 text-sm">7.0" Touch LCD</span>
							</div>
							<div class="bg-white border border-slate-200 rounded p-2 text-center text-xs">
								<span class="block text-xs text-slate-400 uppercase font-mono">Support</span>
								<span class="font-bold text-slate-800 text-sm">TOFD Built-in</span>
							</div>
							<div class="bg-white border border-slate-200 rounded p-2 text-center text-xs">
								<span class="block text-xs text-slate-400 uppercase font-mono">Operation</span>
								<span class="font-bold text-slate-800 text-sm">One-Handed</span>
							</div>
						</div>
					</div>
					<div class="p-6 bg-slate-100 border-t border-slate-200 flex justify-between items-center gap-4">
						<a href="/resources/" class="text-xs font-semibold text-slate-600 hover:text-slate-900">Download Brochure</a>
						<a href="/products/" class="px-4 py-2 text-xs font-bold text-slate-900 bg-primary-cyan rounded hover:bg-cyan-400 transition-colors">Details</a>
					</div>
				</div>
			</div>
			
			<!-- Part 2: Automated & OEM System Boards -->
			<div class="mt-20 border-b border-slate-100 pb-4">
				<div class="flex items-center space-x-3">
					<span class="px-2.5 py-0.5 bg-blue-900 text-[#00E5FF] text-xs font-mono font-bold rounded">CATEGORY 02</span>
					<h3 class="text-lg font-bold text-slate-900">Automated & OEM NDT System Boards</h3>
				</div>
				<p class="text-sm text-slate-500 mt-1">Multi-channel, high-speed acquisition boards optimized for 19-inch industrial standard racks and automated system integrations.</p>
			</div>

			<!-- R5 System Showcase Separator Card -->
			<div class="mt-8 bg-[#0C1929] text-white rounded-xl p-8 border border-slate-800 relative overflow-hidden flex flex-col md:flex-row justify-between items-center gap-8">
				<div class="absolute -right-20 -top-20 w-60 h-60 bg-blue-600/10 rounded-full blur-3xl pointer-events-none"></div>
				<div class="space-y-3 max-w-3xl">
					<div class="inline-block text-xs font-mono bg-blue-900 text-[#00E5FF] px-2 py-0.5 rounded uppercase">Rack-Mount System Scan Engine</div>
					<h3 class="text-2xl font-bold">DEEPSOUND R5 System Board</h3>
					<p class="text-sm text-slate-400 leading-relaxed">
						Supports 19-inch standard rack mounts. Interfaces up to 32 active channels, 128 elements, and 4 dedicated UT ports. Easily scale up multi-board hardware structures utilizing SEONGSANLAB's NDT SDK (DSK).
					</p>
				</div>
				<div class="flex-shrink-0">
					<a href="/products/" class="inline-block bg-white text-slate-900 font-bold px-6 py-3 rounded hover:bg-slate-200 text-xs transition-colors">
						View System Board Specs
					</a>
				</div>
			</div>

			<!-- Part 3: Accessories -->
			<div class="mt-20 border-b border-slate-100 pb-4">
				<div class="flex items-center space-x-3">
					<span class="px-2.5 py-0.5 bg-slate-900 text-primary-cyan text-xs font-mono font-bold rounded">CATEGORY 03</span>
					<h3 class="text-lg font-bold text-slate-900">Precision NDT Accessories</h3>
				</div>
				<p class="text-sm text-slate-500 mt-1">High-value conversion adapter solutions ensuring seamless compatibility with third-party instruments and encoders.</p>
			</div>

			<div class="grid grid-cols-1 md:grid-cols-2 gap-8 mt-8 max-w-4xl mx-auto">
				<!-- Probes & Wedges -->
				<div class="bg-slate-50 border border-slate-200 rounded-xl overflow-hidden hover:border-slate-300 hover:shadow-lg transition-all duration-300 flex flex-col justify-between">
					<div class="p-6 space-y-4">
						<div class="flex justify-between items-start">
							<div>
								<span class="text-xs font-bold text-slate-500 bg-slate-200 px-2 py-0.5 rounded uppercase tracking-wider">Adapter</span>
								<h3 class="text-xl font-bold text-slate-900 mt-2">Universal Probe Converter</h3>
							</div>
						</div>
						<p class="text-sm text-slate-600 leading-relaxed">
							Universal Probe Converter - Streamlines cross-brand probe compatibility and comparative tests without upgrading your entire instrument setup. Compact, lightweight, and engineered for high-mobility.
						</p>
					</div>
					<div class="p-6 bg-slate-100 border-t border-slate-200 flex justify-between items-center gap-4">
						<span class="text-xs text-slate-500">Universal Compatibility</span>
						<a href="/products/" class="px-4 py-2 text-xs font-bold text-slate-900 bg-primary-cyan rounded hover:bg-cyan-400 transition-colors">Details</a>
					</div>
				</div>

				<!-- Scanners -->
				<div class="bg-slate-50 border border-slate-200 rounded-xl overflow-hidden hover:border-slate-300 hover:shadow-lg transition-all duration-300 flex flex-col justify-between">
					<div class="p-6 space-y-4">
						<div class="flex justify-between items-start">
							<div>
								<span class="text-xs font-bold text-slate-500 bg-slate-200 px-2 py-0.5 rounded uppercase tracking-wider">Adapter</span>
								<h3 class="text-xl font-bold text-slate-900 mt-2">Multi-Connector Encoder Converter</h3>
							</div>
						</div>
						<p class="text-sm text-slate-600 leading-relaxed">
							Multi-Connector Encoder Converter - Bridges physical pin-out mismatch and connector type differences between NDT hardware and scan encoders. Extremely cost-effective and portable.
						</p>
					</div>
					<div class="p-6 bg-slate-100 border-t border-slate-200 flex justify-between items-center gap-4">
						<span class="text-xs text-slate-500">Connector Pin-out Standard</span>
						<a href="/products/" class="px-4 py-2 text-xs font-bold text-slate-900 bg-primary-cyan rounded hover:bg-cyan-400 transition-colors">Details</a>
					</div>
				</div>
			</div>
		</div>
	</section>


	<!-- Software Showcase (Core NDT Pillars) -->
	<section id="software" class="py-24 bg-slate-50 scroll-mt-16 border-b border-slate-200">
		<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
			<div class="text-center max-w-3xl mx-auto space-y-4 mb-16">
				<span class="text-xs font-mono bg-blue-100 text-blue-600 px-2 py-0.5 rounded uppercase font-bold">Comprehensive Softwares</span>
				<h2 class="text-3xl font-extrabold text-slate-900 font-display">
					Advanced Acquisition & Analysis Software Suite
				</h2>
				<p class="text-slate-600 text-base">
					SEONGSANLAB designs custom software tools supporting ultrasonic diagnostics from real-time acquisition to expert offline report compile phases.
				</p>
			</div>

			<div class="grid grid-cols-1 md:grid-cols-3 gap-8">
				<!-- DSVision Card -->
				<div class="bg-[#0C1929] text-white border border-slate-800 rounded-xl overflow-hidden hover:border-primary-cyan hover:shadow-xl transition-all duration-300 flex flex-col justify-between">
					<div class="p-6 space-y-4">
						<div class="flex justify-between items-start">
							<div>
								<span class="text-xs font-mono bg-blue-900 text-[#00E5FF] px-2 py-0.5 rounded uppercase font-bold">Real-time Data Acquisition</span>
								<h3 class="text-xl font-bold text-white mt-2">DSVision Acquire</h3>
							</div>
						</div>
						<p class="text-sm text-slate-400 leading-relaxed">
							A real-time ultrasonic data acquisition program optimized for portable instruments. Supports real-time A/B/C/S-Scan imaging and multi-group detection for high-fidelity field diagnostics.
						</p>
						<div class="h-20 bg-slate-950 rounded border border-slate-800 flex items-center justify-between px-3 overflow-hidden font-mono text-xs text-[#00E5FF]/80">
							<div class="space-y-1">
								<div>THICKNESS: 24.5mm</div>
								<div>AMP: 88% FSH</div>
							</div>
							<div class="flex items-end space-x-0.5 h-10 w-24">
								<div class="bg-blue-600/40 w-2 h-3"></div>
								<div class="bg-blue-600/60 w-2 h-6"></div>
								<div class="bg-primary-cyan w-2 h-9"></div>
								<div class="bg-blue-600/60 w-2 h-4"></div>
								<div class="bg-blue-600/40 w-2 h-2"></div>
							</div>
						</div>
					</div>
					<div class="p-6 bg-slate-900 border-t border-slate-800 flex justify-between items-center gap-4 text-xs">
						<span class="text-slate-400">Instrument-embedded SW</span>
						<a href="/products/" class="px-4 py-2 font-bold text-slate-950 bg-primary-cyan rounded hover:bg-cyan-400 transition-colors">Features</a>
					</div>
				</div>

				<!-- DSViewer Card -->
				<div class="bg-[#0C1929] text-white border border-slate-800 rounded-xl overflow-hidden hover:border-primary-cyan hover:shadow-xl transition-all duration-300 flex flex-col justify-between">
					<div class="p-6 space-y-4">
						<div class="flex justify-between items-start">
							<div>
								<span class="text-xs font-mono bg-blue-900 text-[#00E5FF] px-2 py-0.5 rounded uppercase font-bold">Offline Analysis & Reporting</span>
								<h3 class="text-xl font-bold text-white mt-2">DSViewer Analysis</h3>
							</div>
						</div>
						<p class="text-sm text-slate-400 leading-relaxed">
							A dedicated PC analysis software to review and evaluate data files acquired from field operations. Features intuitive mouse dragging to measure defect size/depth, and one-click ASME/ISO standard compliance report generation.
						</p>
						<div class="h-20 bg-slate-950 rounded border border-slate-800 flex items-center justify-center p-2 relative overflow-hidden">
							<div class="w-full h-full border border-slate-800/80 rounded flex items-center justify-between px-3 text-xs font-mono text-[#00E5FF]/80">
								<div class="space-y-1">
									<div>FLAW POSITION: Y=45.2mm</div>
									<div>FLAW SIZE: L=12.4mm</div>
								</div>
								<span class="text-xs bg-red-950 text-red-400 border border-red-900 px-1.5 py-0.5 rounded font-bold">Flaw Detected</span>
							</div>
						</div>
					</div>
					<div class="p-6 bg-slate-900 border-t border-slate-800 flex justify-between items-center gap-4 text-xs">
						<span class="text-slate-400">PC Analysis SW (Offline)</span>
						<a href="/products/" class="px-4 py-2 font-bold text-slate-950 bg-primary-cyan rounded hover:bg-cyan-400 transition-colors">Features</a>
					</div>
				</div>

				<!-- DSK Card -->
				<div class="bg-[#0C1929] text-white border border-slate-800 rounded-xl overflow-hidden hover:border-primary-cyan hover:shadow-xl transition-all duration-300 flex flex-col justify-between">
					<div class="p-6 space-y-4">
						<div class="flex justify-between items-start">
							<div>
								<span class="text-xs font-mono bg-blue-900 text-[#00E5FF] px-2 py-0.5 rounded uppercase font-bold">Software Development Kit</span>
								<h3 class="text-xl font-bold text-white mt-2">DEEPSOUND SDK (DSK)</h3>
							</div>
						</div>
						<p class="text-sm text-slate-400 leading-relaxed">
							A comprehensive developer library (SDK) to interface custom systems with DEEPSOUND hardware. Offers APIs and examples in C++, C#, and Python for industrial automation setups.
						</p>
						<div class="h-20 bg-slate-950 rounded border border-slate-800 p-2 overflow-hidden font-mono text-xs text-green-400/80 leading-snug">
							<div>// SEONGSANLAB DSK API Example</div>
							<div>DSK_InitDevice(DEVICE_ID_P5);</div>
							<div>DSK_StartAcquisition();</div>
							<div>float thickness = DSK_GetThickness();</div>
						</div>
					</div>
					<div class="p-6 bg-slate-900 border-t border-slate-800 flex justify-between items-center gap-4 text-xs">
						<span class="text-slate-400">Developer Library / API</span>
						<a href="/products/" class="px-4 py-2 font-bold text-slate-950 bg-primary-cyan rounded hover:bg-cyan-400 transition-colors">DSK Docs</a>
					</div>
				</div>
			</div>
		</div>
	</section>

	<!-- Technical Resource Hub & Public vs Gated Download Policies -->
	<section id="resources" class="py-24 bg-slate-50 border-t border-b border-slate-200 scroll-mt-16">
		<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
			<div class="grid grid-cols-1 lg:grid-cols-12 gap-12">
				
				<!-- Left Policy info -->
				<div class="lg:col-span-5 space-y-6">
					<h2 class="text-3xl font-extrabold text-slate-900 tracking-tight font-display">
						Technical Document Download Policy
					</h2>
					<p class="text-sm text-slate-600 leading-relaxed">
						To ensure data confidentiality and secure product distribution, SEONGSANLAB classifies technical manuals, certificate docs, and NDT kits into three accessibility bands.
					</p>
					
					<div class="space-y-4">
						<div class="bg-white border border-slate-200 rounded-lg p-4">
							<div class="flex justify-between items-center">
								<h4 class="text-sm font-bold text-slate-900">1. Public Resources</h4>
								<span class="text-xs bg-green-100 text-green-700 px-2 py-0.5 rounded font-bold">INSTANT DOWNLOAD</span>
							</div>
							<p class="text-sm text-slate-500 mt-1">General catalog, high-res hardware brochures, ISO certificates, and company profile guides.</p>
						</div>
						
						<div class="bg-white border border-slate-200 rounded-lg p-4">
							<div class="flex justify-between items-center">
								<h4 class="text-sm font-bold text-slate-900">2. Gated Resources (Lead Verification)</h4>
								<span class="text-xs bg-blue-100 text-blue-700 px-2 py-0.5 rounded font-bold">REQUIRES CORPORATE EMAIL</span>
							</div>
							<p class="text-sm text-slate-500 mt-1">Detailed hardware user manuals, software setup installers, and training course notes.</p>
						</div>
						
						<div class="bg-white border border-slate-200 rounded-lg p-4">
							<div class="flex justify-between items-center">
								<h4 class="text-sm font-bold text-slate-900">3. Restricted Resources (Approval Only)</h4>
								<span class="text-xs bg-red-100 text-red-700 px-2 py-0.5 rounded font-bold">MANUAL INSPECT</span>
							</div>
							<p class="text-sm text-slate-500 mt-1">Ultrasonic SDK files (DSK), probe wiring board blueprints, and calibration parameter files.</p>
						</div>
					</div>
				</div>
				
				<!-- Right Hub Preview / Grid -->
				<div class="lg:col-span-7 space-y-6">
					<div class="bg-white border border-slate-200 rounded-xl p-6 shadow-sm">
						<h3 class="text-lg font-bold text-slate-900 pb-4 border-b border-slate-100">Featured Technical Downloads</h3>
						
						<div class="divide-y divide-slate-100 text-xs">
							{[
								{ title: "DEEPSOUND P5 / B3 General Brochure", type: "Catalog", size: "3.2 MB", gate: "Public" },
								{ title: "DEEPSOUND T3 Ultra-light TOFD Spec Sheet", type: "Datasheet", size: "1.8 MB", gate: "Public" },
								{ title: "DSVision Software User Manual v3.2", type: "Manual", size: "12.4 MB", gate: "Lead Gate" },
								{ title: "DEEPSOUND P5 Core Instrument Operator Manual", type: "Manual", size: "8.9 MB", gate: "Lead Gate" },
								{ title: "SEONGSANLAB DSK (SDK) Library & Examples", type: "Developer Pack", size: "45.0 MB", gate: "Approval Only" }
							].map((doc) => (
								<div class="py-4 flex justify-between items-center">
									<div>
										<h4 class="font-bold text-slate-950">{doc.title}</h4>
										<div class="flex space-x-3 text-xs text-slate-400 mt-1">
											<span>TYPE: {doc.type}</span>
											<span>SIZE: {doc.size}</span>
										</div>
									</div>
									<div>
										{doc.gate === 'Public' && (
											<a href="/resources/" class="px-3 py-1.5 bg-slate-900 text-white rounded font-bold text-xs hover:bg-slate-800 transition-colors">Download</a>
										)}
										{doc.gate === 'Lead Gate' && (
											<a href="#contact-sales" class="px-3 py-1.5 bg-[#3B82F6] text-white rounded font-bold text-xs hover:bg-blue-600 transition-colors">Unlock (Verify)</a>
										)}
										{doc.gate === 'Approval Only' && (
											<a href="#contact-sales" class="px-3 py-1.5 bg-red-600 text-white rounded font-bold text-xs hover:bg-red-700 transition-colors">Request Access</a>
										)}
									</div>
								</div>
							))}
						</div>
					</div>
				</div>
				
			</div>
		</div>
	</section>

	<!-- Company Showcase (About SEONGSANLAB) -->
	<section id="about" class="py-24 bg-[#0C1929] text-white relative overflow-hidden border-t border-b border-slate-800 scroll-mt-16">
		<div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top,_var(--tw-gradient-stops))] from-blue-900/20 via-transparent to-transparent pointer-events-none"></div>
		<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
			<div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-center">
				<div class="lg:col-span-5 space-y-6">
					<span class="text-xs font-mono bg-primary-cyan text-slate-950 px-2.5 py-0.5 rounded font-bold uppercase tracking-wider">Company Profile</span>
					<h2 class="text-3xl font-extrabold tracking-tight font-display text-white">
						SEONGSANLAB Co., Ltd.
					</h2>
					<p class="text-sm text-slate-300 leading-relaxed">
						SEONGSANLAB Co., Ltd. is a technology-driven pioneer dedicated to industrial safety, integrating state-of-the-art ultrasonic Non-Destructive Testing (NDT) hardware with intelligent software systems.
					</p>
					<p class="text-sm text-slate-400 leading-relaxed">
						Driven by the core belief that relentless research and development constitute the lifeblood of industrial innovation, we fully internalize our entire product cycle—from circuit design and embedded firmware to real-time signal processing and desktop analytical suites.
					</p>
				</div>
				
				<div class="lg:col-span-7 grid grid-cols-1 sm:grid-cols-2 gap-6">
					<div class="bg-slate-900/50 border border-slate-800 rounded-xl p-6 hover:border-slate-700 transition-colors">
						<h4 class="text-sm font-bold text-primary-cyan mb-2">Core Competencies</h4>
						<p class="text-xs text-slate-400 leading-relaxed">Leveraging our researchers' proprietary technologies, we specialize in high-precision PAUT/TOFD hardware manufacture and custom multi-channel 32/128PR OEM board integration.</p>
					</div>
					<div class="bg-slate-900/50 border border-slate-800 rounded-xl p-6 hover:border-slate-700 transition-colors">
						<h4 class="text-sm font-bold text-primary-cyan mb-2">DEEPSOUND Brand</h4>
						<p class="text-xs text-slate-400 leading-relaxed">We engineer and deliver the high-performance, ultra-portable DEEPSOUND NDT instrument family alongside dedicated real-time acquisition and desktop analysis software packages.</p>
					</div>
					<div class="bg-slate-900/50 border border-slate-800 rounded-xl p-6 hover:border-slate-700 transition-colors">
						<h4 class="text-sm font-bold text-primary-cyan mb-2">Global Partnerships</h4>
						<p class="text-xs text-slate-400 leading-relaxed">By opening our proprietary Software Development Kit (DSK) library, we cultivate powerful technical synergies with universities, aerospace agencies, and automation partners globally.</p>
					</div>
					<div class="bg-slate-900/50 border border-slate-800 rounded-xl p-6 hover:border-slate-700 transition-colors">
						<h4 class="text-sm font-bold text-primary-cyan mb-2">Our Location</h4>
						<p class="text-xs text-white leading-relaxed font-bold">SEONGSANLAB Headquarters & Lab</p>
						<p class="text-xs text-slate-400 leading-relaxed mt-1">#1318, Ace High-Tech City, 52, Gondan-ro 140beon-gil, Gunpo-si, Gyeonggi-do, Republic of Korea</p>
					</div>
				</div>
			</div>
		</div>
	</section>

	<!-- Technical Inquiry / Request Quote Form Section -->
	<section id="contact-sales" class="py-24 bg-white">
		<div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
			<div class="text-center space-y-4 mb-16">
				<span class="text-xs font-mono bg-primary-cyan/15 text-slate-900 px-2 py-0.5 rounded uppercase font-bold">Product Inquiry & Technical Support</span>
				<h2 class="text-3xl font-extrabold text-slate-900 font-display">
					Contact SEONGSANLAB Technical Support & Sales
				</h2>
				<p class="text-slate-600 text-base max-w-xl mx-auto">
					Need customized rack boards, pricing for the DEEPSOUND P5, or access to restricted user manuals? Complete the form below.
				</p>
			</div>
			
			<!-- Secure input Form -->
			<div class="bg-slate-50 border border-slate-200 rounded-2xl p-8 md:p-12 shadow-sm relative">
				<form class="space-y-6">
					<div class="grid grid-cols-1 md:grid-cols-2 gap-6">
						<div>
							<label for="name" class="block text-xs font-bold text-slate-700 uppercase mb-2">Your Name *</label>
							<input type="text" id="name" name="name" required class="w-full bg-white border border-slate-200 rounded-md px-4 py-3 text-sm focus:border-primary-cyan focus:outline-none" placeholder="e.g. John Doe" />
						</div>
						<div>
							<label for="company" class="block text-xs font-bold text-slate-700 uppercase mb-2">Company Name *</label>
							<input type="text" id="company" name="company" required class="w-full bg-white border border-slate-200 rounded-md px-4 py-3 text-sm focus:border-primary-cyan focus:outline-none" placeholder="e.g. NDT Inspections Ltd." />
						</div>
					</div>
					
					<div class="grid grid-cols-1 md:grid-cols-2 gap-6">
						<div>
							<label for="email" class="block text-xs font-bold text-slate-700 uppercase mb-2">Corporate Email *</label>
							<input type="email" id="email" name="email" required class="w-full bg-white border border-slate-200 rounded-md px-4 py-3 text-sm focus:border-primary-cyan focus:outline-none" placeholder="john@company.com" />
						</div>
						<div>
							<label for="country" class="block text-xs font-bold text-slate-700 uppercase mb-2">Country / Region *</label>
							<input type="text" id="country" name="country" required class="w-full bg-white border border-slate-200 rounded-md px-4 py-3 text-sm focus:border-primary-cyan focus:outline-none" placeholder="e.g. United Kingdom" />
						</div>
					</div>
					
					<div>
						<label for="inquiry-type" class="block text-xs font-bold text-slate-700 uppercase mb-2">Inquiry Type *</label>
						<select id="inquiry-type" name="inquiry_type" required class="w-full bg-white border border-slate-200 rounded-md px-4 py-3 text-sm focus:border-primary-cyan focus:outline-none text-slate-700">
							<option value="">-- Please Select --</option>
							<option value="quote">Request Hardware Price Quote (P5 / B3 / T3 / R5)</option>
							<option value="manual">Request Restricted Document Access (DSK / Setup Installers)</option>
							<option value="technical">Direct Technical Consulting with SEONGSANLAB Engineers</option>
							<option value="partner">Distributor / Agency Partnership Proposal</option>
						</select>
					</div>
					
					<div>
						<label for="message" class="block text-xs font-bold text-slate-700 uppercase mb-2">Message Details *</label>
						<textarea id="message" name="message" required rows="5" class="w-full bg-white border border-slate-200 rounded-md px-4 py-3 text-sm focus:border-primary-cyan focus:outline-none" placeholder="Specify your inspection requirements or interest models."></textarea>
					</div>
					
					<!-- Legal Consent Checkbox (Privacy Safeguard) -->
					<div class="relative flex items-start">
						<div class="flex items-center h-5">
							<input id="privacy-consent" name="privacy-consent" type="checkbox" required class="focus:ring-primary-cyan h-4 w-4 text-slate-900 border-slate-300 rounded" />
						</div>
						<div class="ml-3 text-xs">
							<label for="privacy-consent" class="font-medium text-slate-600">I consent to the collection & processing of my personal information by SEONGSANLAB for support & sales purposes as outlined in the <a href="/resources/" class="text-primary-cyan hover:underline">Privacy Policy</a>. *</label>
						</div>
					</div>
					
					<div>
						<button type="submit" class="w-full py-4 text-sm font-bold text-slate-950 bg-primary-cyan hover:bg-[#00cbe6] rounded-md shadow-md hover:shadow-lg transition-all duration-200">
							Send Secure Technical Inquiry
						</button>
					</div>
				</form>
			</div>
		</div>
	</section>
</Layout>
