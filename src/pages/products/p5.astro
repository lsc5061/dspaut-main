---
import Layout from '../../layouts/Layout.astro';

const portalUrl = import.meta.env.PUBLIC_PORTAL_URL || "https://support.dspaut.com";
const web3FormsKey = import.meta.env.PUBLIC_WEB3FORMS_KEY || "YOUR_ACCESS_KEY_HERE";
---

<Layout 
	title="DSPAUT P5 | Portable Phased Array Ultrasonic NDT Instrument" 
	description='Explore the DSPAUT P5 by SEONGSANLAB. Featuring a 12.1" display, 32:128PR channel configuration, multi-group PAUT + TOFD, and real-time TFM/FMC capabilities.'
	lang="en"
>
	<!-- Product Hero Section -->
	<section class="relative bg-[#0C1929] text-white overflow-hidden py-20 sm:py-28 border-b border-slate-800">
		<div class="absolute -top-40 left-1/4 w-96 h-96 bg-primary-cyan/15 rounded-full blur-[100px] pointer-events-none"></div>
		<div class="absolute -bottom-40 right-1/4 w-96 h-96 bg-blue-600/10 rounded-full blur-[100px] pointer-events-none"></div>
		
		<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
			<div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-center">
				<!-- Hero Left Content -->
				<div class="lg:col-span-7 space-y-6">
					<div class="inline-flex items-center space-x-2 bg-slate-900 border border-slate-800 rounded-full px-3.5 py-1 text-sm text-primary-cyan font-semibold tracking-wide">
						<span>Flagship Portable PAUT</span>
					</div>
					<h1 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold tracking-tight font-display leading-tight">
						DSPAUT P5<br/>
						<span class="text-transparent bg-clip-text bg-gradient-to-r from-primary-cyan to-blue-400">High-Performance PAUT & TOFD</span>
					</h1>
					<p class="text-lg text-slate-300 leading-relaxed max-w-2xl">
						The DSPAUT P5 is a premium portable Phased Array Ultrasonic Testing (PAUT) instrument designed for high-resolution defect detection. Equipped with a glove-friendly 12.1" wide touchscreen, it delivers outstanding operation speed, deep multi-group configuration, and raw TFM/FMC data processing for the most demanding field NDT environments.
					</p>
					
					<div class="flex flex-wrap gap-3 pt-4">
						<a href="#contact-quote" class="px-6 py-3.5 text-sm font-bold text-slate-900 bg-primary-cyan hover:bg-cyan-400 rounded-lg shadow-lg shadow-primary-cyan/20 transition-all duration-200 hover:-translate-y-0.5">
							Request a Quote
						</a>
						<a href="/assets/docs/ENG_Catalog_P5.pdf" target="_blank" class="px-6 py-3.5 text-sm font-bold text-slate-300 border border-slate-700 hover:border-slate-500 hover:text-white rounded-lg transition-all duration-200 hover:-translate-y-0.5">
							Download Catalog (PDF)
						</a>
					</div>
				</div>
				
				<!-- Hero Right Image -->
				<div class="lg:col-span-5 relative flex justify-center items-center">
					<div class="absolute w-80 h-80 bg-primary-cyan/15 rounded-full blur-[60px]"></div>
					<!-- P5 Front Mockup Visual with premium glassmorphism shadows -->
					<div class="relative bg-slate-950/40 border border-slate-800/80 rounded-2xl p-4 backdrop-blur-sm shadow-2xl overflow-hidden group">
						<img 
							src="/assets/img/hardware/portable/P5_Catalog_main.png" 
							alt="DSPAUT P5 Front View" 
							class="w-full max-w-sm h-auto object-contain rounded-lg transform transition-transform duration-500 scale-[1.15] translate-y-1 group-hover:scale-[1.2]"
						/>
					</div>
				</div>
			</div>
		</div>
	</section>

	<!-- Quick Spec Highlights -->
	<section class="bg-slate-900 border-b border-slate-800 py-10 text-slate-300">
		<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
			<div class="grid grid-cols-2 md:grid-cols-4 gap-6 text-center">
				<div class="space-y-1">
					<span class="block text-2xl font-bold text-white">32:128PR</span>
					<span class="text-sm uppercase tracking-wider text-slate-400 font-sans font-semibold">PAUT Configuration</span>
				</div>
				<div class="w-px h-12 bg-slate-800 hidden md:block self-center mx-auto"></div>
				<div class="space-y-1">
					<span class="block text-2xl font-bold text-white">12.1" TFT LCD</span>
					<span class="text-sm uppercase tracking-wider text-slate-400 font-sans font-semibold">Resistive Touchscreen</span>
				</div>
				<div class="w-px h-12 bg-slate-800 hidden md:block self-center mx-auto"></div>
				<div class="space-y-1">
					<span class="block text-2xl font-bold text-white">Max 30 kHz</span>
					<span class="text-sm uppercase tracking-wider text-slate-400 font-sans font-semibold">Pulse Repetition Freq</span>
				</div>
				<div class="w-px h-12 bg-slate-800 hidden md:block self-center mx-auto"></div>
				<div class="space-y-1">
					<span class="block text-2xl font-bold text-white">PAUT + TOFD</span>
					<span class="text-sm uppercase tracking-wider text-slate-400 font-sans font-semibold">Multi-Group Support</span>
				</div>
			</div>
		</div>
	</section>

	<!-- Detailed Product Features -->
	<section class="py-20 bg-white">
		<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 space-y-24">
			
			<!-- Feature 1: Fast Operation & PRF -->
			<div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-center">
				<div class="lg:col-span-5 relative order-last lg:order-first">
					<div class="bg-slate-50 border border-slate-200 rounded-2xl p-6 shadow-sm">
						<img 
							src="/assets/img/hardware/portable/p5_interactive.png" 
							alt="DSPAUT P5 Interactive Touchscreen Operation" 
							class="w-full h-auto object-contain rounded-xl"
						/>
					</div>
				</div>
				<div class="lg:col-span-7 space-y-4">
					<span class="text-sm font-bold font-sans text-primary-cyan bg-slate-900 px-2.5 py-1.5 rounded inline-block mb-2">PROCESSING VELOCITY</span>
					<h2 class="text-3xl font-bold text-slate-900 tracking-tight font-display">
						Instantaneous Operation & Max 30kHz PRF
					</h2>
					<p class="text-slate-600 leading-relaxed text-base">
						Unlike standard NDT equipment, the DSPAUT P5 features an incredibly optimized operating architecture, ensuring responsive operations with zero delay. Supporting Pulse Repetition Frequencies (PRF) up to 30kHz, the P5 enables rapid scanning and seamless real-time data collection when paired with industrial encoders. Experience rapid focal law angle switching and instant depth scale adjustments in the field.
					</p>
					<ul class="space-y-2 text-sm text-slate-600 font-medium">
						<li class="flex items-center space-x-2">
							<span class="text-primary-cyan">✔</span>
							<span>High-speed real-time data processing without frame drops</span>
						</li>
						<li class="flex items-center space-x-2">
							<span class="text-primary-cyan">✔</span>
							<span>Dynamic PRF range adjusting up to 30kHz</span>
						</li>
						<li class="flex items-center space-x-2">
							<span class="text-primary-cyan">✔</span>
							<span>Immediate rendering of Sectorial and Linear scans</span>
						</li>
					</ul>
				</div>
			</div>

			<!-- Feature 2: High Resolution Imaging & TFM -->
			<div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-center">
				<div class="lg:col-span-7 space-y-4">
					<span class="text-sm font-bold font-sans text-primary-cyan bg-slate-900 px-2.5 py-1.5 rounded inline-block mb-2">IMAGE QUALITY</span>
					<h2 class="text-3xl font-bold text-slate-900 tracking-tight font-display">
						Superior Axial Resolution & TFM / FMC
					</h2>
					<p class="text-slate-600 leading-relaxed text-base">
						Equipped with advanced beamforming algorithms, the P5 produces visible differences in beam focusing, enabling technicians to clearly distinguish between closely adjacent defects. For cutting-edge inspections, it supports Total Focusing Method (TFM) and Full Matrix Capture (FMC), allowing raw FMC data export to support research institutions and corporate partner R&D.
					</p>
					<ul class="space-y-2 text-sm text-slate-600 font-medium">
						<li class="flex items-center space-x-2">
							<span class="text-primary-cyan">✔</span>
							<span>Excellent axial resolution for separating micro-defects</span>
						</li>
						<li class="flex items-center space-x-2">
							<span class="text-primary-cyan">✔</span>
							<span>Supports raw TFM/FMC data export via proprietary API</span>
						</li>
						<li class="flex items-center space-x-2">
							<span class="text-primary-cyan">✔</span>
							<span>Highly intuitive color-coded C-scan corrosion thickness mapping</span>
						</li>
					</ul>
				</div>
				<div class="lg:col-span-5">
					<!-- TFM Image Area -->
					<div class="bg-slate-50 border border-slate-200 rounded-2xl p-4 shadow-sm flex items-center justify-center overflow-hidden group">
						<img 
							src="/assets/img/hardware/portable/P5_Front_main.png" 
							alt="DSPAUT P5 High Resolution Scans" 
							class="max-w-full h-auto object-contain rounded-lg transition-transform duration-300 group-hover:scale-[1.03] filter drop-shadow-sm"
						/>
					</div>
				</div>
			</div>

			<!-- Feature 3: Remote Desktop Connection -->
			<div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-center">
				<div class="lg:col-span-5 relative order-last lg:order-first">
					<div class="bg-slate-950/50 border border-slate-800/80 rounded-2xl p-4 backdrop-blur-sm shadow-xl overflow-hidden">
						<img 
							src="/assets/img/hardware/portable/p5_system.png" 
							alt="DSPAUT P5 NDT System Configuration" 
							class="w-full h-auto object-contain rounded-xl"
						/>
					</div>
				</div>
				<div class="lg:col-span-7 space-y-4">
					<span class="text-sm font-bold font-sans text-primary-cyan bg-slate-900 px-2.5 py-1.5 rounded inline-block mb-2">REMOTE OPERATIONS</span>
					<h2 class="text-3xl font-bold text-slate-900 tracking-tight font-display">
						Ethernet-Based Remote Control Connection
					</h2>
					<p class="text-slate-600 leading-relaxed text-base">
						The DSPAUT P5 supports a Remote Connection feature via Gigabit Ethernet, allowing engineers to run the DSVision acquisition suite directly on a laboratory desktop or laptop. This feature is ideal for remote monitoring in hazardous testing areas, or when performing CPU-heavy analyses that demand higher performance from a dedicated PC workstation.
					</p>
					<ul class="space-y-2 text-sm text-slate-600 font-medium">
						<li class="flex items-center space-x-2">
							<span class="text-primary-cyan">✔</span>
							<span>Gigabit Ethernet LAN connection support</span>
						</li>
						<li class="flex items-center space-x-2">
							<span class="text-primary-cyan">✔</span>
							<span>Perfect for hazardous field setups or clean laboratory stations</span>
						</li>
					</ul>
				</div>
			</div>

		</div>
	</section>

	<!-- Software Interface Showcase Section -->
	<section class="py-20 bg-slate-900 text-slate-100 border-b border-slate-800">
		<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
			<div class="text-center max-w-3xl mx-auto space-y-4 mb-16">
				<span class="text-sm font-bold font-sans bg-slate-950 text-primary-cyan px-3 py-1.5 rounded border border-slate-800 inline-block mb-2">NDT SOFTWARE UI</span>
				<h2 class="text-3xl font-extrabold font-display">
					Advanced Real-Time Diagnostic Visualizations
				</h2>
				<p class="text-slate-400 text-sm">
					The DSPAUT system offers comprehensive visualization modes for professional technicians, delivering high-density data representation with high-contrast UI tailored for field use.
				</p>
			</div>

			<div class="grid grid-cols-1 md:grid-cols-2 gap-10 max-w-6xl mx-auto">
				<!-- UI Screen 1 -->
				<div class="space-y-4">
					<div class="bg-slate-950/60 border border-slate-850 rounded-2xl p-4 shadow-xl">
						<img 
							src="/assets/img/software/dsvision/p5_ui_single.png" 
							alt="DSPAUT Thickness & Corrosion Mapping Interface" 
							class="w-full h-auto object-contain rounded-xl"
						/>
					</div>
					<div class="space-y-1 px-2">
						<h3 class="text-md font-bold text-white font-display">Thickness & Corrosion Mapping View</h3>
						<p class="text-sm text-slate-400 leading-relaxed">
							Real-time C-scan thickness mapping interface. The screen displays a color-coded C-scan topographical layout (demonstrated by the mapped "DSPAUT" test piece) combined with active A-scan and B-scan views to detect precise material wall thinning and corrosion.
						</p>
					</div>
				</div>

				<!-- UI Screen 2 -->
				<div class="space-y-4">
					<div class="bg-slate-950/60 border border-slate-850 rounded-2xl p-4 shadow-xl">
						<img 
							src="/assets/img/software/dsvision/p5_ui_multi.png" 
							alt="DSPAUT Multi-Group PAUT + TOFD Software Interface" 
							class="w-full h-auto object-contain rounded-xl"
						/>
					</div>
					<div class="space-y-1 px-2">
						<h3 class="text-md font-bold text-white font-display">Multi-Group PAUT + TOFD Simultaneous View</h3>
						<p class="text-sm text-slate-400 leading-relaxed">
							Advanced configuration allowing operators to view dual sectorial scans (S-scan) at differing focal laws side-by-side with an active TOFD (Time-of-Flight Diffraction) B-scan for dual-channel precision.
						</p>
					</div>
				</div>
			</div>
		</div>
	</section>

	<!-- Hardware Interface & Ports Map -->
	<section class="py-20 bg-slate-50 border-t border-b border-slate-200">
		<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
			<div class="text-center max-w-3xl mx-auto space-y-4 mb-16">
				<span class="text-sm font-bold font-sans bg-slate-900 text-primary-cyan px-3 py-1.5 rounded inline-block mb-2">HARDWARE INTERFACE</span>
				<h2 class="text-3xl font-extrabold text-slate-900 font-display">
					Comprehensive Physical Interface Map
				</h2>
				<p class="text-slate-600 text-sm">
					The DSPAUT P5 is built to coordinate with multiple probe types and encoders. It features two optional probe port configs (TC-ZIF or IPEX) and various I/O ports.
				</p>
			</div>

			<div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-center max-w-5xl mx-auto">
				<!-- Left Ports config -->
				<div class="bg-white border border-slate-200 rounded-2xl p-6 shadow-sm flex flex-col justify-between items-center text-center space-y-6">
					<h3 class="text-lg font-bold text-slate-900">Left Side Connections (Sensor & Encoder)</h3>
					<div class="relative w-full aspect-square max-w-xs flex items-center justify-center bg-slate-50 rounded-xl border border-slate-100 p-4">
						<img 
							src="/assets/img/hardware/portable/P5_omni_Port_1.png" 
							alt="P5 Left Side Ports" 
							class="max-w-full max-h-48 object-contain rounded-lg scale-[1.15] translate-y-1 transition-transform duration-300"
						/>
					</div>
					<div class="text-left w-full space-y-3">
						<div class="border-b border-slate-100 pb-2">
							<span class="block text-sm font-bold text-slate-800">IPEX 160p Connector</span>
							<span class="text-sm text-slate-600">MiniDLP IPEX 160p connector for secure probe attachment.</span>
						</div>
						<div class="border-b border-slate-100 pb-2">
							<span class="block text-sm font-bold text-slate-800">Multi-axis Encoder Port (D-sub 15pin)</span>
							<span class="text-sm text-slate-600">Supports 3-axis scanner encoders for displacement tracking.</span>
						</div>
						<div>
							<span class="block text-sm font-bold text-slate-800">2x UT Lemo 00 Connectors</span>
							<span class="text-sm text-slate-600">Dedicated dual-channel ultrasonic pulse-receive LEMO ports.</span>
						</div>
					</div>
				</div>

				<!-- Right Ports Config -->
				<div class="bg-white border border-slate-200 rounded-2xl p-6 shadow-sm flex flex-col justify-between items-center text-center space-y-6">
					<h3 class="text-lg font-bold text-slate-900">Right Side Connections (Standard I/O & Power)</h3>
					<div class="relative w-full aspect-square max-w-xs flex items-center justify-center bg-slate-50 rounded-xl border border-slate-100 p-4">
						<img 
							src="/assets/img/hardware/portable/KakaoTalk_20241011_111607862_21.png" 
							alt="P5 Right Side Connections" 
							class="max-w-full max-h-48 object-contain rounded-lg scale-[1.25] translate-y-2 transition-transform duration-300"
						/>
					</div>
					<div class="text-left w-full space-y-3">
						<div class="border-b border-slate-100 pb-2">
							<span class="block text-sm font-bold text-slate-800">Standard I/O: USB, HDMI, LAN</span>
							<span class="text-sm text-slate-600">Enables high-speed file transfer, external monitor output, and remote network stream control.</span>
						</div>
						<div>
							<span class="block text-sm font-bold text-slate-800">DC Input Jack</span>
							<span class="text-sm text-slate-600">DC power input for operation and charging internal hot-swappable batteries.</span>
						</div>
					</div>
				</div>
			</div>
		</div>
	</section>

	<!-- Industrial Applications Section -->
	<section class="py-20 bg-slate-50 border-t border-slate-200">
		<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
			<div class="text-center max-w-3xl mx-auto space-y-4 mb-16">
				<span class="text-sm font-bold font-sans bg-slate-900 text-primary-cyan px-3 py-1.5 rounded inline-block mb-2">APPLICATIONS</span>
				<h2 class="text-3xl font-extrabold text-slate-900 font-display">
					Key NDT Inspection Applications
				</h2>
				<p class="text-slate-600 text-sm">
					The DSPAUT P5 is built to deliver precision and reliability across critical industrial sectors, ensuring safety and compliance under the most demanding testing environments.
				</p>
			</div>

			<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8">
				<!-- App 1 -->
				<div class="bg-white border border-slate-200 rounded-2xl p-6 shadow-sm hover:shadow-md transition-shadow duration-200 flex flex-col space-y-4">
					<div class="w-12 h-12 rounded-xl bg-primary-cyan/10 flex items-center justify-center text-primary-cyan">
						<svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" /></svg>
					</div>
					<h3 class="text-md font-bold text-slate-900 font-display">Power Generation & Piping</h3>
					<p class="text-sm text-slate-600 leading-relaxed">
						High-resolution weld inspection in high-temperature pipelines, monitoring stress corrosion cracking (SCC), and thermal fatigue.
					</p>
				</div>
				<!-- App 2 -->
				<div class="bg-white border border-slate-200 rounded-2xl p-6 shadow-sm hover:shadow-md transition-shadow duration-200 flex flex-col space-y-4">
					<div class="w-12 h-12 rounded-xl bg-primary-cyan/10 flex items-center justify-center text-primary-cyan">
						<svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" /></svg>
					</div>
					<h3 class="text-md font-bold text-slate-900 font-display">Shipbuilding & Offshore</h3>
					<p class="text-sm text-slate-600 leading-relaxed">
						Comprehensive testing of thick butt-weld joints, hull structures, and critical structural connections in harsh offshore yards.
					</p>
				</div>
				<!-- App 3 -->
				<div class="bg-white border border-slate-200 rounded-2xl p-6 shadow-sm hover:shadow-md transition-shadow duration-200 flex flex-col space-y-4">
					<div class="w-12 h-12 rounded-xl bg-primary-cyan/10 flex items-center justify-center text-primary-cyan">
						<svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2m0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" /></svg>
					</div>
					<h3 class="text-md font-bold text-slate-900 font-display">Petrochemical & Storage</h3>
					<p class="text-sm text-slate-600 leading-relaxed">
						Precise remaining wall-thickness measurements and C-scan corrosion mapping on pressure vessels, refinery columns, and storage tanks.
					</p>
				</div>
				<!-- App 4 -->
				<div class="bg-white border border-slate-200 rounded-2xl p-6 shadow-sm hover:shadow-md transition-shadow duration-200 flex flex-col space-y-4">
					<div class="w-12 h-12 rounded-xl bg-primary-cyan/10 flex items-center justify-center text-primary-cyan">
						<svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8" /></svg>
					</div>
					<h3 class="text-md font-bold text-slate-900 font-display">Aerospace & Composites</h3>
					<p class="text-sm text-slate-600 leading-relaxed">
						Detailed inspection of carbon fiber reinforced polymers (CFRP) and honeycomb panels to identify micro-voids and delaminations.
					</p>
				</div>
			</div>
		</div>
	</section>

	<!-- Technical Specifications Table -->
	<section class="py-20 bg-white">
		<div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
			<h2 class="text-3xl font-bold text-slate-900 text-center tracking-tight font-display mb-12">
				Technical Specifications
			</h2>

			<div class="border border-slate-200 rounded-2xl overflow-hidden shadow-sm">
				<table class="w-full text-sm text-left text-slate-600">
					<thead class="text-sm uppercase bg-slate-900 text-primary-cyan font-sans">
						<tr>
							<th class="px-6 py-4">Specification Category</th>
							<th class="px-6 py-4">DSPAUT P5 Values</th>
						</tr>
					</thead>
					<tbody class="divide-y divide-slate-100">
						<!-- Category: General -->
						<tr class="bg-slate-50 font-bold text-slate-900">
							<td colspan="2" class="px-6 py-3 font-sans text-sm uppercase text-slate-500 tracking-wider">General & Mechanical</td>
						</tr>
