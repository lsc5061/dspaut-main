---
import Layout from '../../layouts/Layout.astro';

const portalUrl = import.meta.env.PUBLIC_PORTAL_URL || "https://support.dspaut.com";
const web3FormsKey = import.meta.env.PUBLIC_WEB3FORMS_KEY || "YOUR_ACCESS_KEY_HERE";
---

<Layout 
	title="DSPAUT ZTO | Portable Probe Converter Adapter" 
	description="Connect standard third-party Phased Array probes to your DSPAUT instrument using the DSPAUT ZTO Converter. Features lightweight aluminum body, 30-40% cost efficiency, and 160p to 260p port conversion."
	lang="en"
>
	<!-- Product Hero Section -->
	<section class="relative bg-[#0C1929] text-white overflow-hidden py-20 sm:py-28 border-b border-slate-800">
		<div class="absolute -top-40 left-1/4 w-96 h-96 bg-primary-cyan/15 rounded-full blur-[100px] pointer-events-none"></div>
		<div class="absolute -bottom-40 right-1/4 w-96 h-96 bg-blue-600/10 rounded-full blur-[100px] pointer-events-none"></div>
		
		<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
			<div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-center">
				<!-- Hero Left Content -->
				<div class="lg:col-span-7 space-y-6">
					<div class="inline-flex items-center space-x-2 bg-slate-900 border border-slate-880 rounded-full px-3.5 py-1 text-sm text-primary-cyan font-semibold tracking-wide">
						<span>NDT Hardware Adaptability</span>
					</div>
					<h1 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold tracking-tight font-display leading-tight">
						DSPAUT ZTO<br/>
						<span class="text-transparent bg-clip-text bg-gradient-to-r from-primary-cyan to-blue-400">Portable Probe Converter</span>
					</h1>
					<p class="text-lg text-slate-300 leading-relaxed max-w-2xl">
						Maximize legacy sensor investments and eliminate the burden of purchasing new ultrasonic sensors every time equipment is changed. Developed by SEONGSANLAB, the DSPAUT ZTO is a premium palm-sized aluminum adapter designed to map standard third-party IPEX 160-pin probes directly to DSPAUT 260-pin ZIF instrumentation.
					</p>
					
					<div class="flex flex-wrap gap-3 pt-4">
						<a href="#contact-quote" class="px-6 py-3.5 text-sm font-bold text-slate-900 bg-primary-cyan hover:bg-cyan-400 rounded-lg shadow-lg shadow-primary-cyan/20 transition-all duration-200 hover:-translate-y-0.5">
							Inquire Now
						</a>
						<a href="#specifications" class="px-6 py-3.5 text-sm font-bold text-slate-300 border border-slate-700 hover:border-slate-550 hover:text-white rounded-lg transition-all duration-200 hover:-translate-y-0.5">
							View Specifications
						</a>
					</div>
				</div>
				
				<!-- Hero Right Image -->
				<div class="lg:col-span-5 relative flex justify-center items-center">
					<div class="absolute w-80 h-80 bg-primary-cyan/15 rounded-full blur-[60px]"></div>
					<div class="relative bg-slate-950/40 border border-slate-880/85 rounded-2xl p-4 backdrop-blur-sm shadow-2xl overflow-hidden group">
						<img 
							src="/assets/img/hardware/accessories/zto_main.png" 
							alt="DSPAUT ZTO Probe Converter Adapter" 
							class="w-full max-w-md h-64 object-contain rounded-lg transform transition-transform duration-500 group-hover:scale-[1.05]"
						/>
					</div>
				</div>
			</div>
		</div>
	</section>

	<!-- Quick Spec Highlights -->
	<section class="bg-slate-900 border-b border-slate-800 py-10 text-slate-300">
		<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
			<div class="grid grid-cols-2 md:grid-cols-4 gap-6 text-center">
				<div class="space-y-1">
					<span class="block text-2xl font-bold text-white">240 g</span>
					<span class="text-sm uppercase tracking-wider text-slate-400 font-sans font-semibold">Compact & Light Weight</span>
				</div>
				<div class="w-px h-12 bg-slate-800 hidden md:block self-center mx-auto"></div>
				<div class="space-y-1">
					<span class="block text-2xl font-bold text-white">IPEX 160p</span>
					<span class="text-sm uppercase tracking-wider text-slate-400 font-sans font-semibold">Female Input Port</span>
				</div>
				<div class="w-px h-12 bg-slate-800 hidden md:block self-center mx-auto"></div>
				<div class="space-y-1">
					<span class="block text-2xl font-bold text-white">TC-ZIF 260p</span>
					<span class="text-sm uppercase tracking-wider text-slate-400 font-sans font-semibold">Male Output Port</span>
				</div>
				<div class="w-px h-12 bg-slate-800 hidden md:block self-center mx-auto"></div>
				<div class="space-y-1">
					<span class="block text-2xl font-bold text-white">Aluminum (AL)</span>
					<span class="text-sm uppercase tracking-wider text-slate-400 font-sans font-semibold">Lightweight & Sturdy Body</span>
				</div>
			</div>
		</div>
	</section>

	<!-- Detailed Product Features -->
	<section class="py-20 bg-white">
		<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 space-y-24">
			
			<!-- Feature 1: Seamless Adapter Integration -->
			<div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-center">
				<div class="lg:col-span-6 space-y-4">
					<span class="text-sm font-bold font-sans text-primary-cyan bg-slate-900 px-2.5 py-1.5 rounded inline-block mb-2">KEY ADVANTAGES</span>
					<h2 class="text-3xl sm:text-4xl font-bold text-slate-900 tracking-tight font-display">
						Palm-Sized High-Durability Adaptability
					</h2>
					<p class="text-slate-600 leading-relaxed text-lg">
						The DSPAUT ZTO Converter bridges the brand gap between standard industrial probes and DSPAUT systems. Highly recommended for inspection agencies looking to utilize existing sensor infrastructure while transitioning to high-speed digital instrumentation.
					</p>
					<ul class="space-y-3 text-base text-slate-600 font-medium">
						<li class="flex items-start space-x-2">
							<span class="text-primary-cyan mt-1">✔</span>
							<span><strong>Comfortable Portability:</strong> Compact and flexible cable-integrated design optimized for tight scaffolding and field NDT settings.</span>
						</li>
						<li class="flex items-start space-x-2">
							<span class="text-primary-cyan mt-1">✔</span>
							<span><strong>Outstanding Cost Savings:</strong> Experience 30% to 40% lower costs compared to buying expensive imported converters or brand-new probes.</span>
						</li>
						<li class="flex items-start space-x-2">
							<span class="text-primary-cyan mt-1">✔</span>
							<span><strong>Rugged Aluminum Casing:</strong> Anodized metal shield housing protects delicate interior pins from drops, impacts, and heavy vibration.</span>
						</li>
					</ul>
				</div>
				<div class="lg:col-span-6 space-y-6">
					<div class="bg-slate-50 border border-slate-200 rounded-2xl p-6 shadow-sm flex flex-col justify-center space-y-4">
						<h3 class="text-xl font-bold text-slate-900">Developed by SEONGSANLAB</h3>
						<p class="text-slate-600 text-base leading-relaxed">
							Since 2011, SEONGSANLAB (성산연구소) has been at the forefront of Phased Array UT diagnostic hardware design. Every DSPAUT ZTO adapter undergoes rigorous laboratory testing to ensure zero signal lag, standard 50 Ω impedance matching, and seamless data transfer.
						</p>
						<div class="border-t border-slate-200 pt-4 grid grid-cols-2 gap-4 text-sm font-sans text-slate-600">
							<div>
								<span class="block font-bold text-slate-700">Origin</span>
								<span>100% Made in South Korea</span>
							</div>
							<div>
								<span class="block font-bold text-slate-700">Shielding Level</span>
								<span>Double Shielded Coaxial Layout</span>
							</div>
						</div>
					</div>
					
					<!-- Connector Pin Detail Grid -->
					<div class="grid grid-cols-2 gap-4">
						<div class="bg-slate-50 border border-slate-200 rounded-xl p-4 flex flex-col items-center shadow-sm">
							<img src="/assets/img/hardware/accessories/zto_connector_plug.png" alt="Latch-lock connector plug layout" class="h-24 object-contain rounded-lg" />
							<span class="text-sm font-semibold text-slate-600 mt-2 font-sans">Latch-Lock Interface (260P)</span>
						</div>
						<div class="bg-slate-50 border border-slate-200 rounded-xl p-4 flex flex-col items-center shadow-sm">
							<img src="/assets/img/hardware/accessories/zto_perspective.png" alt="ZTO adapter casing layout" class="h-24 object-contain rounded-lg" />
							<span class="text-sm font-semibold text-slate-600 mt-2 font-sans">Adapter Module (ZTO-260P)</span>
						</div>
					</div>
				</div>
			</div>			</div>
			</div>

		</div>
	</section>

	<!-- Technical Specifications Table -->
	<section id="specifications" class="py-20 bg-slate-50 border-t border-b border-slate-200 scroll-mt-24">
		<div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
			<h2 class="text-3xl sm:text-4xl font-bold text-slate-900 text-center tracking-tight font-display mb-12">
				Technical Specifications
			</h2>

			<div class="border border-slate-200 rounded-2xl overflow-hidden shadow-sm bg-white">
				<table class="w-full text-base sm:text-lg text-left text-slate-600">
					<thead class="text-sm sm:text-base uppercase bg-slate-900 text-primary-cyan font-sans">
						<tr>
							<th class="px-6 py-4.5">Specification Category</th>
							<th class="px-6 py-4.5">DSPAUT ZTO Converter Values</th>
						</tr>
					</thead>
					<tbody class="divide-y divide-slate-150">
						<tr class="bg-slate-50/80 font-bold text-slate-900">
							<td colspan="2" class="px-6 py-4 font-sans text-sm sm:text-base uppercase text-slate-500 tracking-wider">Electrical & Signal</td>
						</tr>
						<tr>
							<td class="px-6 py-4 font-medium text-slate-900">Signal Attenuation</td>
							<td class="px-6 py-4">&lt; 0.2 dB (at 5 MHz, optimized for 0.5-15 MHz band)</td>
						</tr>
						<tr>
							<td class="px-6 py-4 font-medium text-slate-900">Impedance</td>
							<td class="px-6 py-4">50 Ω standard match</td>
						</tr>
						<tr>
							<td class="px-6 py-4 font-medium text-slate-900">Maximum Channels</td>
							<td class="px-6 py-4">128 element mapping (supports 16:64, 32:128)</td>
						</tr>
						
						<tr class="bg-slate-50/80 font-bold text-slate-900">
							<td colspan="2" class="px-6 py-4 font-sans text-sm sm:text-base uppercase text-slate-500 tracking-wider">Mechanical & Connectors</td>
						</tr>
						<tr>
							<td class="px-6 py-4 font-medium text-slate-900">Input Port (Female)</td>
							<td class="px-6 py-4">IPEX minidock 160-Pin (Universal Omniscan standard)</td>
						</tr>
						<tr>
							<td class="px-6 py-4 font-medium text-slate-900">Output Port (Male)</td>
							<td class="px-6 py-4">TC-ZIF 260-Pin (DSPAUT native instrument layout)</td>
						</tr>
						<tr>
							<td class="px-6 py-4 font-medium text-slate-900">Housing Material</td>
							<td class="px-6 py-4">Precision CNC-milled Anodized Aluminum (AL)</td>
						</tr>
						<tr>
							<td class="px-6 py-4 font-medium text-slate-900">Dimensions</td>
							<td class="px-6 py-4">84.6 mm (W) × 67.3 mm (H) × 25.4 mm (D)</td>
						</tr>
						<tr>
							<td class="px-6 py-4 font-medium text-slate-900">Weight</td>
							<td class="px-6 py-4">240g (Lightweight handheld bridge)</td>
						</tr>
					</tbody>
				</table>
			</div>
		</div>
	</section>

	<!-- Connection Diagram & Perspective Section -->
	<section class="py-20 bg-white border-t border-b border-slate-200">
		<div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
			<div class="text-center max-w-3xl mx-auto space-y-4 mb-12">
				<span class="text-sm font-bold font-sans bg-slate-900 text-primary-cyan px-2.5 py-1.5 rounded inline-block mb-2">CONNECTION FLOW</span>
				<h2 class="text-3xl sm:text-4xl font-extrabold text-slate-900 font-display">
					DSPAUT ZTO Connection Flow & Outer Shell Perspective
				</h2>
				<p class="text-slate-600 text-lg">
					Visual mapping flow and physical perspective diagram for legacy probe signal conversions.
				</p>
			</div>

			<div class="grid grid-cols-1 md:grid-cols-12 gap-8 items-center">
				<div class="md:col-span-7 bg-slate-50 border border-slate-200 rounded-2xl p-6 shadow-sm">
					<span class="block text-sm font-bold text-slate-855 font-sans mb-4 text-center">P5 Instrument Integration</span>
					<img 
						src="/assets/img/hardware/accessories/zto_diagram.png" 
						alt="ZTO connected to P5 instrument" 
						class="w-full h-auto object-contain rounded-xl"
					/>
				</div>
				<div class="md:col-span-5 bg-slate-50 border border-slate-200 rounded-2xl p-6 shadow-sm flex flex-col justify-between h-full">
					<div>
						<span class="block text-sm font-bold text-slate-855 font-sans mb-4 text-center">Product Perspective View</span>
						<img 
							src="/assets/img/hardware/accessories/zto_perspective.png" 
							alt="ZTO adapter perspective view" 
							class="w-full h-auto object-contain rounded-xl transform transition-transform duration-300 hover:scale-[1.03]"
						/>
					</div>
					<p class="text-sm text-slate-500 mt-4 leading-relaxed text-center">
						* The 3D visualization represents technical schematics designed for physical wiring reference and shielding configuration.
					</p>
				</div>
			</div>
		</div>
	</section>

	<!-- Contact CTA Form Section -->
	<section id="contact-quote" class="py-20 bg-slate-900 text-white relative">
		<div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 space-y-8 relative z-10 text-center">
			<h2 class="text-3xl sm:text-4xl font-extrabold font-display text-white">
				Inquire About DSPAUT ZTO
			</h2>
			<p class="text-slate-400 text-lg max-w-xl mx-auto">
				Tell us your legacy probe model and your target DSPAUT instrument configuration. We will custom map the adapter to match your precise testing parameters.
			</p>
			
			<div class="bg-slate-950 border border-slate-850 rounded-2xl p-8 text-left max-w-xl mx-auto shadow-2xl">
				<form action="https://api.web3forms.com/submit" method="POST" class="space-y-4">
					<input type="hidden" name="access_key" value={web3FormsKey} />
					<input type="hidden" name="subject" value="DSPAUT ZTO Probe Converter Adapter Inquiry" />
					<input type="hidden" name="from_name" value="DSPAUT Main Website" />
					<input type="checkbox" name="botcheck" class="hidden" style="display: none;" />

					<div class="grid grid-cols-2 gap-4">
						<div class="space-y-1.5">
							<label for="name" class="block text-sm uppercase font-bold text-slate-400 font-sans">Your Name *</label>
							<input type="text" name="name" id="name" required class="w-full bg-slate-900 border border-slate-800 rounded px-3 py-2.5 text-lg text-white focus:outline-none focus:border-primary-cyan" />
						</div>
						<div class="space-y-1.5">
							<label for="company" class="block text-sm uppercase font-bold text-slate-400 font-sans">Company *</label>
							<input type="text" name="company" id="company" required class="w-full bg-slate-900 border border-slate-800 rounded px-3 py-2.5 text-lg text-white focus:outline-none focus:border-primary-cyan" />
						</div>
					</div>
					
					<div class="space-y-1.5">
						<label for="email" class="block text-sm uppercase font-bold text-slate-400 font-sans">Email Address *</label>
						<input type="email" name="email" id="email" required class="w-full bg-slate-900 border border-slate-800 rounded px-3 py-2.5 text-lg text-white focus:outline-none focus:border-primary-cyan" />
					</div>

					<div class="space-y-1.5">
						<label for="message" class="block text-sm uppercase font-bold text-slate-400 font-sans">Inquiry / Legacy Probe Model Details *</label>
						<textarea name="message" id="message" rows="4" placeholder="Specify your third-party probe manufacturer (e.g., Olympus 5L64-A12), element layout, and how many units you require..." class="w-full bg-slate-900 border border-slate-800 rounded px-3 py-2.5 text-lg text-white focus:outline-none focus:border-primary-cyan"></textarea>
					</div>

					<button type="submit" class="w-full bg-primary-cyan text-slate-950 font-bold py-3.5 rounded hover:bg-cyan-400 text-base transition-colors tracking-wide uppercase shadow-md shadow-primary-cyan/20">
						Submit Inquiry
					</button>
				</form>
			</div>
		</div>
	</section>
</Layout>
