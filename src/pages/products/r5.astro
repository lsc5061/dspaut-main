	<!-- Contact CTA Form Section -->
	<section id="contact-quote" class="py-20 bg-slate-900 text-white relative">
		<div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 space-y-8 relative z-10 text-center">
			<h2 class="text-3xl sm:text-4xl font-extrabold font-display text-white">
				Request R5 Spec & OEM Inquiry
			</h2>
			<p class="text-slate-400 text-lg max-w-xl mx-auto">
				Submit your company details and automated NDT scanner project requirements. Our technical R&D and integration engineers will contact you.
			</p>
			
			<div class="bg-slate-950 border border-slate-850 rounded-2xl p-8 text-left max-w-xl mx-auto shadow-2xl">
				<form action="https://api.web3forms.com/submit" method="POST" class="space-y-4">
					<input type="hidden" name="access_key" value={web3FormsKey} />
					<input type="hidden" name="subject" value="DSPAUT R5 OEM / Automation Request" />
					<input type="hidden" name="from_name" value="DSPAUT Main Website" />
					<input type="checkbox" name="botcheck" class="hidden" style="display: none;" />

					<div class="grid grid-cols-2 gap-4">
						<div class="space-y-1.5">
							<label for="name" class="block text-sm uppercase font-bold text-slate-400 font-sans">Your Name</label>
							<input type="text" name="name" id="name" required class="w-full bg-slate-900 border border-slate-800 rounded px-3 py-2.5 text-lg text-white focus:outline-none focus:border-primary-cyan" />
						</div>
						<div class="space-y-1.5">
							<label for="company" class="block text-sm uppercase font-bold text-slate-400 font-sans">Company</label>
							<input type="text" name="company" id="company" class="w-full bg-slate-900 border border-slate-800 rounded px-3 py-2.5 text-lg text-white focus:outline-none focus:border-primary-cyan" />
						</div>
					</div>
					
					<div class="space-y-1.5">
						<label for="email" class="block text-sm uppercase font-bold text-slate-400 font-sans">Email Address</label>
						<input type="email" name="email" id="email" required class="w-full bg-slate-900 border border-slate-800 rounded px-3 py-2.5 text-lg text-white focus:outline-none focus:border-primary-cyan" />
					</div>

					<div class="space-y-1.5">
						<label for="message" class="block text-sm uppercase font-bold text-slate-400 font-sans">Project Requirements & OEM Inquiries</label>
						<textarea name="message" id="message" rows="4" placeholder="Mention your target factory scanning setups, multiboard configurations, required DSK SDK language interfaces..." class="w-full bg-slate-900 border border-slate-800 rounded px-3 py-2.5 text-lg text-white focus:outline-none focus:border-primary-cyan"></textarea>
					</div>

					<button type="submit" class="w-full bg-primary-cyan text-slate-900 font-bold py-3.5 rounded hover:bg-cyan-400 text-base transition-colors tracking-wide uppercase shadow-md shadow-primary-cyan/20">
						Submit R5 OEM Inquiry
					</button>
				</form>
			</div>
		</div>
	</section>
</Layout>
