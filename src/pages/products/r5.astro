---
import Layout from '../../layouts/Layout.astro';

const portalUrl = import.meta.env.PUBLIC_PORTAL_URL || "https://support.dspaut.com";
const web3FormsKey = import.meta.env.PUBLIC_WEB3FORMS_KEY || "YOUR_ACCESS_KEY_HERE";
---

<Layout 
	title="DSPAUT R5 | Rack-Mount NDT PAUT System Board for Automation" 
	description='Explore the DSPAUT R5 by SEONGSANLAB. A 19" rack-mountable 32:128PR PAUT system board optimized for automated manufacturing lines and custom NDT R&D.'
	lang="en"
>
	<!-- Product Hero Section -->
	<section class="relative bg-[#0C1929] text-white overflow-hidden py-20 sm:py-28 border-b border-slate-800">
		<div class="absolute -top-40 left-1/4 w-96 h-96 bg-primary-cyan/15 rounded-full blur-[100px] pointer-events-none"></div>
		<div class="absolute -bottom-40 right-1/4 w-96 h-96 bg-blue-600/10 rounded-full blur-[100px] pointer-events-none"></div>
		
		<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
			<div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-center">
				<!-- Hero Left Content -->
				<div class="lg:col-span-7 space-y-6">
					<div class="inline-flex items-center space-x-2 bg-slate-900 border border-slate-800 rounded-full px-3.5 py-1.5 text-sm text-primary-cyan font-semibold tracking-wide">
						<span>Automated Inspection & R&D Board</span>
					</div>
					<h1 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold tracking-tight font-display leading-tight">
						DSPAUT R5<br/>
						<span class="text-transparent bg-clip-text bg-gradient-to-r from-primary-cyan to-blue-400">High-Performance OEM PAUT Engine</span>
					</h1>
					<p class="text-lg sm:text-xl text-slate-300 leading-relaxed max-w-2xl">
						The DSPAUT R5 is a cutting-edge 19-inch rack-mountable Phased Array Ultrasonic Testing (PAUT) system specifically designed for automated manufacturing lines and advanced R&D environments. The R5 provides the raw processing power, multi-board scaling, and integration flexibility required for high-volume quality control and experimental research.
					</p>
					
					<div class="flex flex-wrap gap-3 pt-4">
						<a href="#contact-quote" class="px-6 py-3.5 text-base font-bold text-slate-900 bg-primary-cyan hover:bg-cyan-400 rounded-lg shadow-lg shadow-primary-cyan/20 transition-all duration-200 hover:-translate-y-0.5">
							Request R5 OEM Quote
						</a>
						<a href="/assets/docs/ENG_Catalog_R5.pdf" target="_blank" class="px-6 py-3.5 text-base font-bold text-slate-300 border border-slate-700 hover:border-slate-500 hover:text-white rounded-lg transition-all duration-200 hover:-translate-y-0.5">
							Download Catalog (PDF)
						</a>
					</div>
				</div>
				
				<!-- Hero Right Image -->
				<div class="lg:col-span-5 relative flex justify-center items-center">
					<div class="absolute w-80 h-80 bg-primary-cyan/15 rounded-full blur-[60px]"></div>
					<div class="relative bg-slate-950/40 border border-slate-800/80 rounded-2xl p-4 backdrop-blur-sm shadow-2xl overflow-hidden group">
						<img 
							src="/assets/img/hardware/oem/r5_front_view.png" 
							alt="DSPAUT R5 OEM Rackmount System" 
							class="w-full max-w-md h-auto object-contain rounded-lg transform transition-transform duration-500 scale-100 group-hover:scale-[1.05]"
						/>
					</div>
				</div>
			</div>
		</div>
	</section>

	<!-- Quick Spec Highlights -->
	<section class="bg-slate-900 border-b border-slate-800 py-10 text-slate-300">
		<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
			<div class="grid grid-cols-2 md:grid-cols-4 gap-6 text-center">
				<div class="space-y-1">
					<span class="block text-2xl sm:text-3xl font-bold text-white">19" Rack</span>
					<span class="text-sm sm:text-base uppercase tracking-wider text-slate-500 font-sans font-semibold">Standard Form Factor</span>
				</div>
				<div class="w-px h-12 bg-slate-800 hidden md:block self-center mx-auto"></div>
				<div class="space-y-1">
					<span class="block text-2xl sm:text-3xl font-bold text-white">32:128PR</span>
					<span class="text-sm sm:text-base uppercase tracking-wider text-slate-500 font-sans font-semibold">PAUT Configuration</span>
				</div>
				<div class="w-px h-12 bg-slate-800 hidden md:block self-center mx-auto"></div>
				<div class="space-y-1">
					<span class="block text-2xl sm:text-3xl font-bold text-white">Max 30 kHz</span>
					<span class="text-sm sm:text-base uppercase tracking-wider text-slate-500 font-sans font-semibold">Pulse Repetition Freq</span>
				</div>
				<div class="w-px h-12 bg-slate-800 hidden md:block self-center mx-auto"></div>
				<div class="space-y-1">
					<span class="block text-2xl sm:text-3xl font-bold text-white">DSK Support</span>
					<span class="text-sm sm:text-base uppercase tracking-wider text-slate-500 font-sans font-semibold">C# SDK</span>
				</div>
			</div>
		</div>
	</section>

	<!-- Detailed Product Features -->
	<section class="py-20 bg-white">
		<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 space-y-24">
			
			<!-- Feature 1: Industrial Scalability -->
			<div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-center">
				<div class="lg:col-span-5 relative order-last lg:order-first">
					<div class="bg-slate-50 border border-slate-200 rounded-2xl p-6 shadow-sm">
						<img 
							src="/assets/img/hardware/oem/r5_perspective.png" 
							alt="DSPAUT R5 Rack Integration details" 
							class="w-full h-auto object-contain rounded-xl shadow-md transform transition-transform duration-300 hover:scale-[1.03]"
						/>
					</div>
				</div>
				<div class="lg:col-span-7 space-y-4">
					<span class="text-sm font-bold font-sans text-primary-cyan bg-slate-900 px-2.5 py-1.5 rounded inline-block mb-2">SCALABLE ARCHITECTURE</span>
					<h2 class="text-3xl sm:text-4xl font-bold text-slate-900 tracking-tight font-display">
						Industrial Scalability: 19" Rack-Mount Design
					</h2>
					<p class="text-slate-600 leading-relaxed text-lg">
						Experience seamless integration into your existing factory infrastructure. The R5 is optimized for industrial rack systems, allowing for stable, multi-channel configurations. It is equipped with a built-in standalone PC, so there's no need to connect external hardware control units.
					</p>
					<ul class="space-y-3 text-base text-slate-600 font-medium">
						<li class="flex items-start space-x-2">
							<span class="text-primary-cyan mt-1">✔</span>
							<span><strong>19-Inch Rack Compatibility:</strong> Standard rack-mount form factor for organized, secure, and compact multi-unit operation.</span>
						</li>
						<li class="flex items-start space-x-2">
							<span class="text-primary-cyan mt-1">✔</span>
							<span><strong>Standalone Operation:</strong> Built-in PC inside. Simply connect a monitor via HDMI and run inspection programs directly.</span>
						</li>
						<li class="flex items-start space-x-2">
							<span class="text-primary-cyan mt-1">✔</span>
							<span><strong>Multi-Board Expansion:</strong> Stack multiple units to accommodate high-volume factory automated scanner lines.</span>
						</li>
					</ul>
				</div>
			</div>

			<!-- Feature 2: C# SDK & Signal Processing -->
			<div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-center">
				<div class="lg:col-span-7 space-y-4">
					<span class="text-sm font-bold font-sans text-primary-cyan bg-slate-900 px-2.5 py-1.5 rounded inline-block mb-2">C# SYSTEM INTEGRATION</span>
					<h2 class="text-3xl sm:text-4xl font-bold text-slate-900 tracking-tight font-display">
						Advanced Multi-Channel Processing & Flexible C# DSK Integration
					</h2>
					<p class="text-slate-600 leading-relaxed text-lg">
						The DSPAUT R5 features a high-performance hardware architecture designed for precise multi-channel ultrasonic signal computation. It seamlessly processes dense data streams from 32:128PR Phased Array and 4-channel Conventional UT configurations. For quick integration, it supports a dedicated C# DSK API/SDK to program custom automation UI screens and hardware control algorithms.
					</p>
					<ul class="space-y-3 text-base text-slate-600 font-medium">
						<li class="flex items-start space-x-2">
							<span class="text-primary-cyan mt-1">✔</span>
							<span><strong>32:128PR High-Fidelity Signal:</strong> Handles linear, sectoral, and single conventional UT probe inputs with zero data loss.</span>
						</li>
						<li class="flex items-start space-x-2">
							<span class="text-primary-cyan mt-1">✔</span>
							<span><strong>C#-Dedicated DSK SDK:</strong> Features optimized .NET API classes for rapid development of control logic and customized inspection dashboards.</span>
						</li>
						<li class="flex items-start space-x-2">
							<span class="text-primary-cyan mt-1">✔</span>
							<span><strong>Real-Time Data Streaming:</strong> Streams acoustic raw data over a 1Gbps Ethernet connection directly to your remote PC without latency.</span>
						</li>
					</ul>
				</div>
				<!-- SDK Code snippet showcase card -->
				<div class="lg:col-span-5">
					<div class="bg-slate-950 border border-slate-800 rounded-2xl p-6 shadow-xl font-mono text-sm text-slate-300">
						<div class="flex items-center space-x-2 pb-4 border-b border-slate-900">
							<span class="w-3 h-3 rounded-full bg-red-500"></span>
							<span class="w-3 h-3 rounded-full bg-yellow-500"></span>
							<span class="w-3 h-3 rounded-full bg-green-500"></span>
							<span class="text-slate-500 text-sm pl-2">dsk_api_example.cs</span>
						</div>
						<pre class="pt-4 space-y-1.5 overflow-x-auto text-[13px] leading-relaxed">
<span class="text-blue-400">using</span> <span class="text-cyan-400">System</span>;
<span class="text-blue-400">using</span> <span class="text-cyan-400">DEEPSOUND</span>;

<span class="text-slate-500">// Initialize R5 OEM Board via DSK</span>
<span class="text-yellow-400">DSK</span>.<span class="text-green-400">InitDsk</span>();
<span class="text-blue-400">bool</span> isReady = <span class="text-yellow-400">DSK</span>.<span class="text-green-400">InitDevice</span>();

<span class="text-blue-400">if</span> (isReady) {"{"}
    <span class="text-slate-500">// Configure hardware parameters</span>
    <span class="text-yellow-400">DSK</span>.<span class="text-green-400">SetGain</span>(<span class="text-orange-400">45.0</span>);
    <span class="text-yellow-400">DSK</span>.<span class="text-green-400">SetPulseVoltage</span>(<span class="text-orange-400">120</span>);
    
    <span class="text-slate-500">// Apply parameters to hardware</span>
    <span class="text-yellow-400">DSK</span>.<span class="text-green-400">UploadAllParameters</span>();
{"}"}
						</pre>
					</div>
				</div>
			</div>

		</div>
	</section>

	<!-- Applications Section -->
	<section class="py-20 bg-slate-950 text-white border-t border-b border-slate-900 relative">
		<div class="absolute -top-40 left-1/3 w-96 h-96 bg-primary-cyan/10 rounded-full blur-[120px] pointer-events-none"></div>
		<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
			<div class="text-center max-w-3xl mx-auto space-y-4 mb-16">
				<span class="text-sm font-bold font-sans bg-slate-900 text-primary-cyan px-2.5 py-1.5 rounded inline-block mb-2">KEY APPLICATIONS</span>
				<h2 class="text-3xl sm:text-4xl font-extrabold font-display">
					Target Industrial Applications
				</h2>
				<p class="text-slate-400 text-lg">
					The DSPAUT R5 Phased Array engine is optimized for high-volume automated testing setups and custom scientific R&D platforms.
				</p>
			</div>

			<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
				<!-- App 1 -->
				<div class="bg-slate-900/40 border border-slate-800 rounded-2xl p-6 hover:border-primary-cyan/50 hover:bg-slate-900/60 transition-all duration-300 flex flex-col justify-between group">
					<div class="space-y-4">
						<span class="text-3xl">🏭</span>
						<h3 class="text-xl sm:text-2xl font-bold group-hover:text-primary-cyan transition-colors">In-Line Automated QA</h3>
						<p class="text-base text-slate-400 leading-relaxed">
							Seamlessly integrates with robotic arms and factory conveyor setups for high-speed, 24/7 automated inspection of automotive, steel, and tube parts.
						</p>
					</div>
				</div>

				<!-- App 2 -->
				<div class="bg-slate-900/40 border border-slate-800 rounded-2xl p-6 hover:border-primary-cyan/50 hover:bg-slate-900/60 transition-all duration-300 flex flex-col justify-between group">
					<div class="space-y-4">
						<span class="text-3xl">✈️</span>
						<h3 class="text-xl sm:text-2xl font-bold group-hover:text-primary-cyan transition-colors">Aerospace & Composites</h3>
						<p class="text-base text-slate-400 leading-relaxed">
							Supports automated gantry and water-immersion systems for high-resolution ultrasonic imaging (C-scan) of critical composite materials and wing components.
						</p>
					</div>
				</div>

				<!-- App 3 -->
				<div class="bg-slate-900/40 border border-slate-800 rounded-2xl p-6 hover:border-primary-cyan/50 hover:bg-slate-900/60 transition-all duration-300 flex flex-col justify-between group">
					<div class="space-y-4">
						<span class="text-3xl">🔬</span>
						<h3 class="text-xl sm:text-2xl font-bold group-hover:text-primary-cyan transition-colors">NDT R&D & Custom Rigs</h3>
						<p class="text-base text-slate-400 leading-relaxed">
							Provides an open DSK SDK interface for university researchers and system integrators to write custom scripts and test new beamforming algorithms.
						</p>
					</div>
				</div>

				<!-- App 4 -->
				<div class="bg-slate-900/40 border border-slate-800 rounded-2xl p-6 hover:border-primary-cyan/50 hover:bg-slate-900/60 transition-all duration-300 flex flex-col justify-between group">
					<div class="space-y-4">
						<span class="text-3xl">🚄</span>
						<h3 class="text-xl sm:text-2xl font-bold group-hover:text-primary-cyan transition-colors">Railway & Infrastructure</h3>
						<p class="text-base text-slate-400 leading-relaxed">
							Powers high-speed rolling search units for automatic detection of internal cracks and defects in railway wheelsets, axles, and tracks.
						</p>
					</div>
				</div>
			</div>
		</div>
	</section>

	<!-- Hardware Interface & Ports Map -->
	<section class="py-20 bg-slate-50 border-t border-b border-slate-200">
		<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
			<div class="text-center max-w-3xl mx-auto space-y-4 mb-16">
				<span class="text-sm font-bold font-sans bg-slate-900 text-primary-cyan px-2.5 py-1.5 rounded inline-block mb-2">HARDWARE INTERFACE</span>
				<h2 class="text-3xl sm:text-4xl font-extrabold text-slate-900 font-display">
					DSPAUT R5 Interface & Ports Map
				</h2>
				<p class="text-slate-600 text-lg">
					The DSPAUT R5 layout integrates high-frequency sensor connections and a phased array probe port on the front panel, with power, display, and high-speed communication interfaces on the rear panel.
				</p>
			</div>

			<div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-center max-w-5xl mx-auto">
				<!-- Front Panel Config -->
				<div class="bg-white border border-slate-200 rounded-2xl p-6 shadow-sm flex flex-col justify-between items-center text-center space-y-6">
					<h3 class="text-xl font-bold text-slate-900">Front Panel (Probes & Control)</h3>
					<div class="relative w-full aspect-square max-w-xs flex items-center justify-center bg-slate-50 rounded-xl border border-slate-100 p-4">
						<img 
							src="/assets/img/hardware/oem/3.png" 
							alt="DSPAUT R5 Front Panel Ports" 
							class="max-w-full max-h-48 object-contain rounded-lg scale-[1.1] translate-y-1 transition-transform duration-300"
						/>
					</div>
					<div class="text-left w-full space-y-4">
						<div class="border-b border-slate-100 pb-3">
							<span class="block text-base font-bold text-slate-800">High-Density Phased Array Connector</span>
							<span class="text-base text-slate-500 mt-1 block leading-relaxed">Multi-pin high-density probe connector supporting up to 32:128PR Phased Array configurations.</span>
						</div>
						<div class="border-b border-slate-100 pb-3">
							<span class="block text-base font-bold text-slate-800">4x Conventional UT Ports</span>
							<span class="text-base text-slate-500 mt-1 block leading-relaxed">4 auxiliary coaxial channels (LEMO 00) for standard pulse-echo UT or TOFD probes.</span>
						</div>
						<div>
							<span class="block text-base font-bold text-slate-800">Power Switch & LED Indicators</span>
							<span class="text-base text-slate-500 mt-1 block leading-relaxed">Backlit power button and 3-channel diagnostic LEDs indicating hardware status.</span>
						</div>
					</div>
				</div>

				<!-- Rear Panel Config -->
				<div class="bg-white border border-slate-200 rounded-2xl p-6 shadow-sm flex flex-col justify-between items-center text-center space-y-6">
					<h3 class="text-xl font-bold text-slate-900">Rear Panel (I/O, Video & Communication)</h3>
					<div class="relative w-full aspect-square max-w-xs flex items-center justify-center bg-slate-50 rounded-xl border border-slate-100 p-4">
						<img 
							src="/assets/img/hardware/oem/4.png" 
							alt="DSPAUT R5 Rear Panel Ports" 
							class="max-w-full max-h-48 object-contain rounded-lg scale-[1.1] translate-y-1 transition-transform duration-300"
						/>
					</div>
					<div class="text-left w-full space-y-4">
						<div class="border-b border-slate-100 pb-3">
							<span class="block text-base font-bold text-slate-800">DB25 Encoder / I/O Port</span>
							<span class="text-base text-slate-500 mt-1 block leading-relaxed">25-pin D-sub port supporting 3-axis encoder inputs and hardware trigger synchronization.</span>
						</div>
						<div class="border-b border-slate-100 pb-3">
							<span class="block text-base font-bold text-slate-800">Dual Video Outputs (HDMI & VGA)</span>
							<span class="text-base text-slate-500 mt-1 block leading-relaxed">Support for external monitor connection to display real-time PAUT software UI.</span>
						</div>
						<div>
							<span class="block text-base font-bold text-slate-800">Gigabit Ethernet & USB 3.0</span>
							<span class="text-base text-slate-500 mt-1 block leading-relaxed">High-speed LAN connectivity for raw data streaming and USB ports for system peripherals.</span>
						</div>
					</div>
				</div>
			</div>
		</div>
	</section>

	<!-- Technical Specifications Table -->
	<section class="py-20 bg-slate-50 border-t border-b border-slate-200">
		<div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
			<h2 class="text-3xl sm:text-4xl font-bold text-slate-900 text-center tracking-tight font-display mb-12">
				Technical Specifications
			</h2>

			<div class="border border-slate-200 rounded-2xl overflow-hidden shadow-sm bg-white">
				<table class="w-full text-base sm:text-lg text-left text-slate-600">
					<thead class="text-sm sm:text-base uppercase bg-slate-900 text-primary-cyan font-sans">
						<tr>
							<th class="px-6 py-4.5">Specification Category</th>
							<th class="px-6 py-4.5">DSPAUT R5 Values</th>
						</tr>
					</thead>
					<tbody class="divide-y divide-slate-150">
						<tr class="bg-slate-50/80 font-bold text-slate-900">
							<td colspan="2" class="px-6 py-4 font-sans text-sm sm:text-base uppercase text-slate-500 tracking-wider">General & Mechanical</td>
						</tr>
						<tr>
							<td class="px-6 py-4 font-medium text-slate-900">Form Factor</td>
							<td class="px-6 py-4">19" standard rack mount multi-board design</td>
						</tr>
						<tr>
							<td class="px-6 py-4 font-medium text-slate-900">PC System</td>
							<td class="px-6 py-4">Built-in Standalone Industrial PC</td>
						</tr>
						<tr>
							<td class="px-6 py-4 font-medium text-slate-900">Operating System</td>
							<td class="px-6 py-4">Windows Embedded / Linux support</td>
						</tr>
						
						<tr class="bg-slate-50/80 font-bold text-slate-900">
							<td colspan="2" class="px-6 py-4 font-sans text-sm sm:text-base uppercase text-slate-500 tracking-wider">Acoustic & Configuration</td>
						</tr>
						<tr>
							<td class="px-6 py-4 font-medium text-slate-900">PAUT Configuration</td>
							<td class="px-6 py-4">32:128PR channels</td>
						</tr>
						<tr>
							<td class="px-6 py-4 font-medium text-slate-900">Conventional UT</td>
							<td class="px-6 py-4">4 Channels (LEMO 00 connectors)</td>
						</tr>
						<tr>
							<td class="px-6 py-4 font-medium text-slate-900">Pulser Type</td>
							<td class="px-6 py-4">Bipolar Pulse (25V ~ 190V)</td>
						</tr>
						<tr>
							<td class="px-6 py-4 font-medium text-slate-900">Effective Digitizer</td>
							<td class="px-6 py-4">100 MHz</td>
						</tr>
						<tr>
							<td class="px-6 py-4 font-medium text-slate-900">Max PRF</td>
							<td class="px-6 py-4">Up to 30,000 Hz (30 kHz)</td>
						</tr>
						<tr>
							<td class="px-6 py-4 font-medium text-slate-900">Sample Resolution</td>
							<td class="px-6 py-4">16 bit</td>
						</tr>
						<tr>
							<td class="px-6 py-4 font-medium text-slate-900">Software Support</td>
							<td class="px-6 py-4">DSK (SDK APIs), Custom UI integrations</td>
						</tr>

						<tr class="bg-slate-50/80 font-bold text-slate-900">
							<td colspan="2" class="px-6 py-4 font-sans text-sm sm:text-base uppercase text-slate-500 tracking-wider">Connectivity</td>
						</tr>
						<tr>
							<td class="px-6 py-4 font-medium text-slate-900">I/O Ports</td>
							<td class="px-6 py-4">Fast Gigabit LAN, HDMI out, USB 3.0, 3-Axis Encoder support</td>
						</tr>
					</tbody>
				</table>
			</div>
		</div>
	</section>

	<!-- Resources Section -->
	<section class="py-16 bg-white border-b border-slate-200">
		<div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center space-y-8">
			<h2 class="text-2xl sm:text-3xl font-extrabold text-slate-900 font-display">
				DSPAUT R5 Documents & Support
			</h2>
			<div class="grid grid-cols-1 sm:grid-cols-3 gap-6 max-w-3xl mx-auto">
				<div class="bg-slate-50 p-6 border border-slate-200 rounded-xl shadow-sm flex flex-col justify-between">
					<h4 class="text-lg font-bold text-slate-800">English Catalog</h4>
					<span class="text-base text-slate-400 font-sans block mt-1">PDF · 1.4MB</span>
					<a href="/assets/docs/ENG_Catalog_R5.pdf" target="_blank" class="mt-4 inline-block bg-slate-900 hover:bg-slate-800 text-white font-bold text-base px-4 py-2.5 rounded">Download</a>
				</div>
				<div class="bg-slate-50 p-6 border border-slate-200 rounded-xl shadow-sm flex flex-col justify-between">
					<h4 class="text-lg font-bold text-slate-800">Korean Catalog</h4>
					<span class="text-base text-slate-400 font-sans block mt-1">PDF · 1.5MB</span>
					<a href="/assets/docs/KOR_Catalog_R5.pdf" target="_blank" class="mt-4 inline-block bg-slate-900 hover:bg-slate-800 text-white font-bold text-base px-4 py-2.5 rounded">Download</a>
				</div>
				<div class="bg-slate-50 p-6 border border-slate-200 rounded-xl shadow-sm flex flex-col justify-between">
					<h4 class="text-lg font-bold text-slate-800">DSViewer Manual</h4>
					<span class="text-base text-slate-400 font-sans block mt-1">PDF · 1.8MB</span>
					<a href="/assets/docs/DSViewer_Manual_v2.pdf" target="_blank" class="mt-4 inline-block bg-slate-900 hover:bg-slate-800 text-white font-bold text-base px-4 py-2.5 rounded">Download</a>
